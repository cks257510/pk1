<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>POKEBATTLE</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Pretendard:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <script src="POKEMON_DATABASE.js"></script>
  <script src="POKEMON_DATABASE_2.js"></script>
  <script src="POKEMON_DATABASE_3.js"></script>
  <script src="POKEMON_DATABASE_4.js"></script>
  <script src="POKEMON_DATABASE_35.js"></script>
  <script src="ITEM_DATABASE.js"></script>

  <style>
    :root {
      --bg-main: #02060b;
      --bg-radial: radial-gradient(circle at 50% 28%, #16202d 0%, #0d131c 28%, #05080d 64%, #010204 100%);
      --panel-1: rgba(236, 244, 255, 0.1);
      --panel-2: rgba(198, 217, 241, 0.13);
      --panel-3: rgba(144, 170, 204, 0.09);
      --panel-dark: rgba(14, 20, 31, 0.84);
      --panel-solid: #101722;
      --line: rgba(187, 212, 241, 0.16);
      --line-strong: rgba(194, 225, 255, 0.28);
      --text-main: #f8fbff;
      --text-soft: #b9c8dd;
      --text-muted: #8c9bb0;
      --sky: #b6e2ff;
      --sky-strong: #7ecfff;
      --sky-soft: rgba(126, 207, 255, 0.16);
      --orange: #ffad5a;
      --red: #ff6b6b;
      --green: #68d391;
      --shadow: 0 22px 50px rgba(0, 0, 0, 0.38);
      --radius-xl: 28px;
      --radius-lg: 22px;
      --radius-md: 18px;
      --radius-sm: 14px;
      --nav-h: 88px;
      --safe-top: env(safe-area-inset-top, 0px);
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
      font-family: "Pretendard", "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
    }

    html, body {
      margin: 0;
      width: 100%;
      height: 100%;
      background: #000;
      color: var(--text-main);
      overflow: hidden;
      touch-action: manipulation;
    }

    body {
      background: var(--bg-radial);
    }

    button, input, select {
      font: inherit;
    }

    button {
      border: 0;
      cursor: pointer;
      background: none;
      color: inherit;
    }

    .app-root {
      position: relative;
      width: 100%;
      max-width: 560px;
      height: 100dvh;
      min-height: 100vh;
      margin: 0 auto;
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.015), rgba(255,255,255,0)),
        var(--bg-radial);
    }

    .screen {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .hidden {
      display: none !important;
    }

    .title-screen {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 18px;
      padding: 26px;
      text-align: center;
      background:
        radial-gradient(circle at 50% 35%, rgba(135, 198, 255, 0.14), transparent 28%),
        radial-gradient(circle at 50% 70%, rgba(255,255,255,0.05), transparent 40%),
        var(--bg-radial);
    }

    .title-logo {
      font-size: clamp(2.8rem, 11vw, 4.2rem);
      font-weight: 800;
      letter-spacing: -0.06em;
      line-height: 1;
      text-shadow: 0 10px 35px rgba(126, 207, 255, 0.16);
      user-select: none;
    }

    .title-logo .poke {
      color: var(--sky);
    }

    .title-logo .battle {
      color: #fff;
    }

    .title-subcopy {
      max-width: 320px;
      font-size: 0.98rem;
      line-height: 1.62;
      color: var(--text-soft);
    }

    .title-actions {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-top: 10px;
    }

    .hero-button {
      width: 100%;
      max-width: 340px;
      margin: 0 auto;
      border-radius: 20px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.06));
      box-shadow: var(--shadow);
      padding: 17px 18px;
      font-size: 1rem;
      font-weight: 700;
      transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
      backdrop-filter: blur(16px);
    }

    .hero-button.primary {
      border-color: rgba(170, 222, 255, 0.32);
      background: linear-gradient(180deg, rgba(126, 207, 255, 0.18), rgba(255,255,255,0.08));
    }

    .hero-button:active,
    .chip-btn:active,
    .nav-btn:active,
    .ghost-btn:active,
    .action-button:active,
    .mini-icon-btn:active,
    .move-chip:active,
    .settings-choice:active,
    .pokemon-card:active,
    .reserve-chip:active,
    .trainer-toggle:active {
      transform: scale(0.98);
    }

    .lobby-screen,
    .battle-screen {
      display: flex;
      flex-direction: column;
      min-height: 100%;
      padding-top: calc(var(--safe-top) + 10px);
    }

    .top-shell {
      padding: 12px 14px 12px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      background: linear-gradient(180deg, rgba(5, 8, 13, 0.88), rgba(5, 8, 13, 0.3));
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--line);
      z-index: 5;
    }

    .top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .profile-wrap {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .trainer-avatar {
      position: relative;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid rgba(161, 222, 255, 0.75);
      flex-shrink: 0;
      box-shadow: 0 0 0 4px rgba(255,255,255,0.03);
    }

    .trainer-avatar.red {
      background: radial-gradient(circle at 35% 35%, #8f3249, #5f1728 68%, #3a0b16 100%);
    }

    .trainer-avatar.green {
      background: radial-gradient(circle at 35% 35%, #3f9f68, #156b42 65%, #0e442b 100%);
    }

    .profile-copy {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .trainer-name-row {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .trainer-name {
      font-size: 1.04rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      white-space: nowrap;
    }

    .trainer-name.red { color: #ff7373; }
    .trainer-name.green { color: #73dd9c; }

    .season-label {
      font-size: 0.82rem;
      color: var(--text-soft);
      white-space: nowrap;
    }

    .top-controls {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    .mini-icon-btn,
    .chip-btn,
    .ghost-btn,
    .nav-btn,
    .action-button,
    .settings-choice,
    .trainer-toggle,
    .move-chip {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255,255,255,0.1), rgba(255,255,255,0.05));
      color: var(--text-main);
      backdrop-filter: blur(10px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.15);
      transition: transform 0.16s ease, border-color 0.16s ease, opacity 0.16s ease, background 0.16s ease;
    }

    .mini-icon-btn {
      width: 40px;
      height: 40px;
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }

    .top-second-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .mode-pill {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 9px 12px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.05);
      color: var(--text-soft);
      font-size: 0.82rem;
      font-weight: 700;
    }

    .trainer-switcher {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .trainer-toggle {
      padding: 10px 14px;
      border-radius: 999px;
      font-size: 0.84rem;
      font-weight: 700;
      color: var(--text-soft);
    }

    .trainer-toggle.active {
      color: var(--text-main);
      border-color: var(--line-strong);
      background: linear-gradient(180deg, rgba(126, 207, 255, 0.16), rgba(255,255,255,0.08));
    }

    .content-scroll {
      flex: 1;
      overflow-y: auto;
      overflow-x: hidden;
      padding: 16px 14px calc(var(--nav-h) + 22px + var(--safe-bottom));
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
    }

    .content-scroll::-webkit-scrollbar {
      width: 10px;
    }

    .content-scroll::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.12);
      border-radius: 999px;
      border: 2px solid transparent;
      background-clip: padding-box;
    }

    .panel-card {
      background: linear-gradient(180deg, rgba(255,255,255,0.11), rgba(255,255,255,0.06));
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow);
      padding: 16px;
      backdrop-filter: blur(18px);
    }

    .section-title-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 14px;
    }

    .section-title {
      font-size: 1.08rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin: 0;
    }

    .section-caption {
      margin: 4px 0 0;
      font-size: 0.84rem;
      line-height: 1.55;
      color: var(--text-soft);
    }

    .accent-note {
      color: var(--sky);
      font-weight: 700;
    }

    .squad-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .pokemon-card {
      position: relative;
      padding: 18px 62px 18px 18px;
      border-radius: 24px;
      border: 1px solid var(--line);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.1), rgba(255,255,255,0.06));
      box-shadow: var(--shadow);
      min-height: 320px;
      text-align: left;
      overflow: hidden;
    }

    .pokemon-card::after {
      content: "";
      position: absolute;
      inset: auto -22px -32px auto;
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(126, 207, 255, 0.14), transparent 70%);
      pointer-events: none;
    }

    .pokemon-card.selected {
      border-color: rgba(255, 173, 90, 0.5);
      box-shadow: 0 20px 40px rgba(255, 173, 90, 0.12), var(--shadow);
    }

    .pokemon-head {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      margin-bottom: 14px;
      min-width: 0;
    }

    .avatar-shell {
      flex-shrink: 0;
      width: 72px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding-top: 2px;
    }

    .pokemon-avatar {
      position: relative;
      width: 62px;
      height: 62px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.15);
      box-shadow: 0 10px 20px rgba(0,0,0,0.2);
      flex-shrink: 0;
      overflow: hidden;
    }

    .pokemon-avatar.sprite-avatar {
      border: none;
      box-shadow: none;
      border-radius: 18px;
      background: transparent;
      overflow: visible;
    }

    .pokemon-sprite {
      width: 100%;
      height: 100%;
      object-fit: contain;
      image-rendering: auto;
      filter: drop-shadow(0 8px 14px rgba(0,0,0,0.26));
      display: block;
    }

    .pokemon-sprite-video {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
      filter: drop-shadow(0 8px 14px rgba(0,0,0,0.26));
      background: transparent;
      border-radius: 14px;
    }

    .pokemon-avatar::before,
    .pokemon-avatar::after {
      content: "";
      position: absolute;
      top: 50%;
      width: 20px;
      height: 8px;
      border-radius: 999px;
      transform: translateY(-50%);
      opacity: 0.95;
    }

    .pokemon-avatar::before { left: -13px; }
    .pokemon-avatar::after { right: -13px; }
    .pokemon-avatar.sprite-avatar::before,
    .pokemon-avatar.sprite-avatar::after { display:none; }

    .sprite-battle-mon {
      display:flex;
      align-items:center;
      justify-content:center;
      background:transparent !important;
      box-shadow:none !important;
      overflow:visible;
    }
    .battle-mon-sprite {
      display:block;
      width:auto;
      height:auto;
      object-fit:contain;
      image-rendering:auto;
      filter:drop-shadow(0 10px 18px rgba(0,0,0,0.28));
      background:transparent;
    }
    .battle-mon-video {
      display:block;
      width:auto;
      height:auto;
      object-fit:contain;
      filter:drop-shadow(0 10px 18px rgba(0,0,0,0.28));
      background:transparent;
      border-radius:18px;
    }


    .pokemon-copy {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 7px;
      flex: 1;
    }

    .name-line {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .pokemon-name {
      font-size: 1.18rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #fff;
    }

    .pokemon-level {
      font-size: 0.82rem;
      color: var(--text-muted);
      font-weight: 700;
    }

    .held-item {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 5px 9px;
      border-radius: 999px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      font-size: 0.76rem;
      color: var(--text-soft);
      max-width: 100%;
    }

    .held-shape {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      flex-shrink: 0;
      background: var(--sky);
    }

    .type-row {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }

    .type-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 48px;
      padding: 5px 9px;
      border-radius: 999px;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: -0.01em;
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.14);
      text-shadow: 0 1px 1px rgba(0,0,0,0.22);
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
      margin: 14px 0;
    }

    .stat-box {
      padding: 10px 11px;
      border-radius: 16px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      min-height: 58px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
    }

    .stat-label {
      font-size: 0.73rem;
      color: var(--text-soft);
      font-weight: 600;
      line-height: 1.25;
    }

    .stat-value {
      font-size: 1rem;
      line-height: 1;
      color: var(--sky);
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .stat-value.is-best {
      color: var(--orange);
    }

    .battle-note {
      margin: 0;
      font-size: 0.83rem;
      line-height: 1.68;
      color: var(--text-soft);
      padding-right: 2px;
      white-space: pre-wrap;
      word-break: keep-all;
    }

    .battle-note-emphasis {
      font-size: 0.93rem;
      font-weight: 800;
      color: #edf7ff;
      line-height: 1.8;
    }

    .card-action-area {
      position: absolute;
      right: 14px;
      top: 18px;
      transform: none;
      display: flex;
      flex-direction: row;
      gap: 8px;
      align-items: flex-start;
    }

    .move-chip {
      min-width: 58px;
      min-height: 34px;
      padding: 8px 12px;
      border-radius: 14px;
      writing-mode: horizontal-tb;
      text-orientation: mixed;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.01em;
      color: var(--sky);
      border-color: rgba(126, 207, 255, 0.25);
      background: linear-gradient(180deg, rgba(126, 207, 255, 0.12), rgba(255,255,255,0.06));
    }

    .move-chip:focus-visible,
    .hero-button:focus-visible,
    .nav-btn:focus-visible,
    .mini-icon-btn:focus-visible,
    .action-button:focus-visible,
    .settings-choice:focus-visible,
    .trainer-toggle:focus-visible,
    .reserve-chip:focus-visible,
    .pokemon-card:focus-visible {
      outline: 2px solid rgba(126, 207, 255, 0.45);
      outline-offset: 2px;
    }

    .subsection {
      margin-top: 16px;
    }

    .subheading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 10px;
    }

    .subheading h3 {
      margin: 0;
      font-size: 0.95rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .subheading span {
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    .reserve-panel {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .reserve-chip {
      padding: 11px 12px;
      border-radius: 16px;
      text-align: left;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.05);
      min-height: 74px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .reserve-chip.selected {
      border-color: rgba(255, 173, 90, 0.48);
      background: rgba(255, 173, 90, 0.1);
    }

    .reserve-copy {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
      flex: 1;
    }

    .reserve-name {
      font-size: 0.9rem;
      font-weight: 700;
      color: #fff;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .reserve-meta {
      font-size: 0.74rem;
      color: var(--text-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .empty-state {
      padding: 18px;
      border-radius: 24px;
      border: 1px dashed rgba(255,255,255,0.14);
      background: rgba(255,255,255,0.04);
      color: var(--text-soft);
      font-size: 0.84rem;
      line-height: 1.6;
    }

    .info-banner {
      margin: 12px 0 18px;
      padding: 12px 14px;
      border-radius: 16px;
      border: 1px solid rgba(126,207,255,0.24);
      background: rgba(12,19,30,0.72);
      color: #d8ecff;
      line-height: 1.45;
      font-size: 13px;
    }
    .info-banner strong { color: #8dd7ff; margin-right: 6px; }

    .summary-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 14px;
    }


    .helper-overlay-card {
      margin-top: 14px;
      display:flex;
      align-items:flex-end;
      justify-content:space-between;
      gap:12px;
      padding:14px 16px;
      border-radius:18px;
      background:rgba(255,255,255,.08);
      border:1px solid rgba(255,255,255,.12);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }
    .helper-overlay-card p { margin:6px 0 0; color:#d7e3f3; font-size:.8rem; line-height:1.5; }
    .summary-card {
      padding: 14px;
      border-radius: 24px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .summary-label {
      font-size: 0.78rem;
      color: var(--text-soft);
      margin-bottom: 6px;
      font-weight: 700;
    }

    .summary-value {
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .bottom-nav {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: calc(var(--nav-h) + var(--safe-bottom));
      padding: 8px 12px calc(8px + var(--safe-bottom));
      background: linear-gradient(180deg, rgba(3,5,8,0.25), rgba(4,6,10,0.95) 34%);
      border-top: 1px solid var(--line);
      backdrop-filter: blur(20px);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      z-index: 6;
    }

    .nav-btn {
      border-radius: 24px;
      min-height: 64px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      color: var(--text-muted);
      font-weight: 700;
      font-size: 0.76rem;
      letter-spacing: -0.01em;
      padding: 8px 4px;
    }

    .nav-btn .emoji {
      font-size: 1.15rem;
      line-height: 1;
    }

    .nav-btn.active {
      color: #fff;
      border-color: rgba(126, 207, 255, 0.26);
      background: linear-gradient(180deg, rgba(126, 207, 255, 0.15), rgba(255,255,255,0.08));
    }

    .floating-type-button {
      position: fixed;
      right: calc(12px + env(safe-area-inset-right, 0px));
      bottom: calc(var(--nav-h) + 18px + var(--safe-bottom));
      z-index: 7;
      min-width: 92px;
      padding: 11px 13px;
      border-radius: 999px;
      border: 1px solid rgba(126, 207, 255, 0.24);
      background: linear-gradient(180deg, rgba(126,207,255,0.16), rgba(255,255,255,0.07));
      color: var(--sky);
      font-size: 0.78rem;
      font-weight: 800;
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    .battle-screen .floating-type-button {
      right: 12px;
      bottom: 12px;
      min-width: 68px;
      padding: 8px 10px;
      font-size: 0.72rem;
    }

    .battle-corner-actions {
      position: absolute;
      top: calc(8px + var(--safe-top));
      right: 10px;
      z-index: 6;
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .battle-corner-btn {
      min-width: 72px;
      padding: 7px 10px;
      border-radius: 999px;
      border: 1px solid rgba(93, 156, 220, 0.26);
      background: linear-gradient(180deg, rgba(255,255,255,0.84), rgba(230,239,255,0.66));
      color: #27405f;
      font-size: 0.72rem;
      font-weight: 800;
      box-shadow: 0 8px 18px rgba(52, 83, 119, 0.12);
      backdrop-filter: blur(10px);
    }

    .battle-stat-sheet-grid {
      display: grid;
      gap: 8px;
      margin-top: 10px;
    }

    .battle-stat-sheet-row {
      display: grid;
      grid-template-columns: 52px 1fr;
      gap: 10px;
      align-items: center;
      padding: 10px 12px;
      border-radius: 14px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .battle-stat-sheet-label {
      font-size: 0.82rem;
      font-weight: 800;
      color: var(--text-main);
    }

    .battle-stat-sheet-values {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 12px;
      font-size: 0.8rem;
      color: var(--text-soft);
    }

    .battle-stat-sheet-values strong {
      color: var(--sky);
      font-size: 0.9rem;
    }

    .placeholder-stack {
      display: grid;
      gap: 12px;
    }

    .placeholder-card {
      padding: 16px;
      border-radius: 20px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .placeholder-card h3 {
      margin: 0 0 8px;
      font-size: 0.96rem;
      letter-spacing: -0.02em;
    }

    .placeholder-card p,
    .placeholder-card li {
      margin: 0;
      font-size: 0.84rem;
      line-height: 1.65;
      color: var(--text-soft);
    }

    .placeholder-card ul {
      margin: 10px 0 0;
      padding-left: 18px;
    }

    .overlay {
      position: fixed;
      inset: 0;
      z-index: 30;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 18px;
      background: rgba(0, 0, 0, 0.72);
      backdrop-filter: blur(12px);
    }

    .modal {
      width: min(100%, 520px);
      max-height: min(84dvh, 760px);
      overflow: hidden;
      border-radius: 30px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(20, 28, 40, 0.96), rgba(10, 15, 23, 0.98));
      box-shadow: 0 28px 70px rgba(0,0,0,0.5);
      display: flex;
      flex-direction: column;
    }

    .modal-header {
      padding: 18px 18px 14px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }

    .modal-title-wrap h2 {
      margin: 0;
      font-size: 1.12rem;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .modal-title-wrap p {
      margin: 6px 0 0;
      color: var(--text-soft);
      font-size: 0.8rem;
      line-height: 1.55;
    }

    .close-btn {
      width: 38px;
      height: 38px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.08);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }

    .modal-body {
      overflow-y: auto;
      padding: 16px 18px 20px;
      -webkit-overflow-scrolling: touch;
    }

    .welcome-card {
      text-align: center;
      padding: 24px 22px;
      align-items: center;
    }

    .welcome-card .modal-body {
      padding-top: 10px;
      font-size: 0.95rem;
      line-height: 1.8;
      color: var(--text-soft);
    }

    .welcome-dismiss {
      margin-top: 16px;
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .moves-stack {
      display: grid;
      gap: 12px;
    }

    .move-card {
      padding: 14px;
      border-radius: 24px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .move-head {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 7px;
      margin-bottom: 10px;
    }

    .move-name {
      font-size: 0.98rem;
      font-weight: 800;
      color: #fff;
    }

    .mini-badge {
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 800;
      background: rgba(255,255,255,0.07);
      color: var(--text-soft);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .move-meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
      margin-bottom: 10px;
    }

    .move-meta-inline {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin: 8px 0 12px;
      font-size: 0.84rem;
      color: var(--text-soft);
      font-weight: 700;
    }

    .move-meta-inline strong {
      color: #d7ecff;
      margin-right: 4px;
    }

    .move-meta {
      padding: 10px 11px;
      border-radius: 14px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      font-size: 0.78rem;
      line-height: 1.45;
      color: var(--text-soft);
    }

    .move-meta strong,
    .numeric-emphasis {
      color: var(--sky);
      font-weight: 800;
    }

    .move-description,
    .logic-copy {
      margin: 0;
      font-size: 0.81rem;
      line-height: 1.67;
      color: var(--text-soft);
      white-space: pre-wrap;
      word-break: keep-all;
    }

    .logic-box {
      margin-top: 10px;
      padding: 11px 12px;
      border-radius: 14px;
      background: rgba(126, 207, 255, 0.08);
      border: 1px solid rgba(126, 207, 255, 0.14);
    }

    .settings-grid {
      display: grid;
      gap: 14px;
    }

    .settings-section h3 {
      margin: 0 0 10px;
      font-size: 0.92rem;
      letter-spacing: -0.02em;
    }

    .settings-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .settings-choice {
      padding: 11px 13px;
      border-radius: 14px;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--text-soft);
    }

    .settings-choice.active {
      color: #fff;
      border-color: rgba(126, 207, 255, 0.28);
      background: linear-gradient(180deg, rgba(126, 207, 255, 0.18), rgba(255,255,255,0.08));
    }

    .type-chart-stack {
      display: grid;
      gap: 12px;
    }

    .chart-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 12px;
    }

    .legend-pill {
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 800;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.05);
    }

    .legend-pill.two { color: #ffb36b; }
    .legend-pill.one { color: #d7e8ff; }
    .legend-pill.half { color: #8fd6a8; }
    .legend-pill.zero { color: #ff8888; }
    .legend-pill.stab { color: var(--sky); }

    .type-chart-card {
      padding: 14px;
      border-radius: 24px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .type-chart-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }

    .effect-list {
      display: grid;
      gap: 4px;
      font-size: 0.8rem;
      color: var(--text-soft);
    }

    .effect-group-title {
      font-size: 0.76rem;
      color: var(--text-muted);
      margin-bottom: 4px;
      font-weight: 700;
    }

    .multiplier {
      font-weight: 800;
    }

    .multiplier.two { color: #ffb36b; }
    .multiplier.one { color: #d8ebff; }
    .multiplier.half { color: #87d4a5; }
    .multiplier.zero { color: #ff8b8b; }

    .battle-shell {
      flex: 1;
      display: flex;
      flex-direction: column;
      background: linear-gradient(180deg, #dbe7fb 0%, #cfe0fb 12%, #c8daf7 38%, #10141b 38%, #171b23 100%);
      color: #131820;
    }

    .battle-top {
      min-height: 39%;
      padding: calc(10px + var(--safe-top)) 12px 12px;
      background: linear-gradient(180deg, #cfd9ee 0%, #c6d4ed 10%, #bad1f0 24%, #bdd1ee 58%, #c7d8f2 100%);
      border-bottom: 1px solid rgba(89, 172, 223, 0.22);
      position: relative;
      overflow: hidden;
    }

    .battle-top::before {
      content: "";
      position: absolute;
      inset: 24px 0 auto;
      height: 180px;
      background: repeating-linear-gradient(180deg, rgba(255,255,255,0.18) 0 3px, rgba(255,255,255,0) 3px 22px);
      opacity: 0.7;
      pointer-events: none;
    }

    .battle-top::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: -62px;
      transform: translateX(-50%);
      width: 138%;
      height: 214px;
      background: var(--battle-ground, radial-gradient(circle at center top, rgba(111, 185, 124, 0.98), rgba(86, 152, 103, 0.98) 54%, rgba(65, 128, 79, 1) 100%));
      border-radius: 100% 100% 0 0;
      opacity: 0.84;
      pointer-events: none;
      z-index: 1;
    }

    .battle-screen[data-battle-theme="route"] .battle-shell { background: linear-gradient(180deg, #dcecff 0%, #d6e8ff 13%, #d5e8ff 38%, #10141b 38%, #171b23 100%); }
    .battle-screen[data-battle-theme="route"] .battle-top { background: linear-gradient(180deg, #dff3ff 0%, #d6edff 20%, #d7ecff 60%, #d8eaff 100%); --battle-ground: radial-gradient(circle at center top, rgba(118, 199, 126, .98), rgba(76, 152, 88, .98) 54%, rgba(52, 123, 67, 1) 100%); }
    .battle-screen[data-battle-theme="galaxy"] .battle-shell { background: linear-gradient(180deg, #e8ddff 0%, #d9cef8 14%, #d2c8f2 38%, #110f1a 38%, #1a1724 100%); }
    .battle-screen[data-battle-theme="galaxy"] .battle-top { background: linear-gradient(180deg, #ece2ff 0%, #dacaf8 20%, #c3b6eb 60%, #cbbde8 100%); --battle-ground: radial-gradient(circle at center top, rgba(108, 93, 160, .98), rgba(79, 62, 132, .98) 54%, rgba(56, 39, 100, 1) 100%); }
    .battle-screen[data-battle-theme="distortion"] .battle-shell { background: linear-gradient(180deg, #28132a 0%, #33173a 14%, #4b2353 38%, #120d19 38%, #1a1320 100%); }
    .battle-screen[data-battle-theme="distortion"] .battle-top { background: linear-gradient(180deg, #5b2a63 0%, #67306e 20%, #5b274b 60%, #4f1d43 100%); --battle-ground: radial-gradient(circle at center top, rgba(151, 72, 128, .98), rgba(113, 50, 104, .98) 54%, rgba(66, 23, 58, 1) 100%); }
    .dungeon-card.selected { box-shadow: 0 0 0 1px rgba(255,255,255,.08), 0 14px 34px rgba(0,0,0,.24); }


    .battle-status-card {
      position: relative;
      z-index: 4;
      width: 42%;
      max-width: 320px;
      padding: 14px 16px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(33, 25, 47, 0.96), rgba(44, 35, 62, 0.96));
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: 0 14px 26px rgba(0,0,0,0.16);
    }

    .battle-status-card.enemy {
      margin-left: 0;
    }

    .battle-status-card.ally {
      margin-top: 130px;
      margin-left: auto;
    }

    .battle-status-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }

    .battle-pokemon-name {
      font-weight: 800;
      font-size: 0.98rem;
      color: #f7fbff;
    }

    .battle-level {
      font-size: 0.78rem;
      color: #d7def4;
      font-weight: 700;
    }

    .hp-line {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 6px;
    }

    .hp-bar-wrap {
      flex: 1;
      height: 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.14);
      overflow: hidden;
    }

    .hp-bar {
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, #56ca7b, #88e9a5);
      transition: width 760ms cubic-bezier(0.22, 1, 0.36, 1), background 220ms ease;
    }

    .hp-text,
    .ball-count {
      font-size: 0.74rem;
      color: #eef4ff;
      font-weight: 700;
    }

    .battle-scene {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 3;
    }

    .battle-mon {
      position: absolute;
      opacity: 1;
      width: 88px;
      height: 88px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.42);
      box-shadow: 0 14px 28px rgba(0,0,0,0.18);
      transition: filter 0.14s ease, transform 0.14s ease, opacity 0.14s ease;
      z-index: 3;
    }

    .battle-mon::before,
    .battle-mon::after {
      content: "";
      position: absolute;
      top: 50%;
      width: 30px;
      height: 8px;
      border-radius: 999px;
      transform: translateY(-50%);
      background: currentColor;
      opacity: 0.95;
    }

    .battle-mon::before { left: -19px; }
    .battle-mon::after { right: -19px; }

    
    .battle-types-inline { display:flex; gap:6px; flex-wrap:wrap; align-items:center; margin-left:8px; }
    .battle-types-inline .type-badge { font-size:.68rem; }
    .battle-turn-indicator.red { color:#ff6b6b; font-weight:800; }
    .battle-turn-indicator.green { color:#69d28a; font-weight:800; }
    .battle-mon::before,
    .battle-mon::after { display:none !important; content:none !important; }
    .battle-mon.enemy {
      top: 34%;
      right: 17%;
      transform: scale(0.96);
    }

    .battle-mon.ally {
      bottom: 10%;
      left: 14%;
    }

    .battle-bottom {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 12px 12px calc(14px + var(--safe-bottom));
      background: linear-gradient(180deg, #171c24 0%, #1e242d 100%);
      border-top: 1px solid rgba(133, 210, 255, 0.38);
      box-shadow: inset 0 1px 0 rgba(148, 220, 255, 0.06);
      color: #f7fbff;
    }

    .battle-log {
      min-height: 96px;
      padding: 14px 16px;
      border-radius: 24px;
      border: 1px solid rgba(124, 194, 236, 0.24);
      background: rgba(8, 12, 18, 0.58);
      color: #f7fbff;
      line-height: 1.45;
      font-size: 0.84rem;
      box-shadow: 0 12px 24px rgba(0,0,0,0.18);
      display: flex;
      flex-direction: column;
      gap: 4px;
      overflow: hidden;
    }

    .battle-log-entry {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: #f7fbff;
    }

    .battle-turn-indicator {
      margin: 0 0 10px;
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      color: #d7ecff;
      font-weight: 800;
      letter-spacing: -0.02em;
      text-align: center;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .battle-turn-indicator.hidden {
      display: none;
    }

    .battle-action-grid {
      position: relative;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-top: 12px;
      padding-top: 8px;
      max-height: min(34vh, 300px);
      overflow-y: auto;
      padding-right: 4px;
      overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
    }

    .battle-mini-toggle {
      position: absolute;
      top: -2px;
      right: 2px;
      min-height: 28px;
      padding: 0 10px;
      border-radius: 999px;
      border: 1px solid rgba(139, 213, 255, 0.28);
      background: rgba(28, 35, 44, 0.96);
      color: #dff4ff;
      font-size: 0.68rem;
      font-weight: 800;
      z-index: 2;
    }

    .action-button {
      min-height: 74px;
      border-radius: 24px;
      border: 1px solid rgba(135, 202, 240, 0.18);
      background: linear-gradient(180deg, rgba(245,248,252,0.08), rgba(255,255,255,0.03));
      box-shadow: 0 12px 24px rgba(0,0,0,0.12);
      text-align: left;
      padding: 14px 16px;
      color: #f8fbff;
    }

    .battle-move-button {
      min-height: 128px;
      padding-top: 20px;
    }

    .battle-move-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 8px;
      margin-bottom: 6px;
    }

    .battle-type-pill,
    .battle-category-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 22px;
      padding: 0 9px;
      border-radius: 999px;
      font-size: 0.69rem;
      font-weight: 800;
      letter-spacing: 0.01em;
    }

    .battle-category-pill.physical { background: rgba(255, 122, 122, 0.18); color: #ff9d9d; border: 1px solid rgba(255, 134, 134, 0.22); }
    .battle-category-pill.special { background: rgba(115, 193, 255, 0.18); color: #9ddcff; border: 1px solid rgba(115, 193, 255, 0.22); }
    .battle-category-pill.status { background: rgba(191, 161, 255, 0.16); color: #d0bfff; border: 1px solid rgba(191, 161, 255, 0.2); }

    .battle-move-description {
      margin-top: 8px;
      font-size: 0.72rem;
      line-height: 1.46;
      color: #dceeff;
      opacity: 0.96;
      display: flex;
      flex-direction: column;
      gap: 6px;
      overflow: hidden;
    }

    .battle-matchup {
      color: #9fe3b9;
      font-weight: 700;
    }

    .battle-pp-pill { background: rgba(255,255,255,0.08); color: #dceeff; border: 1px solid rgba(255,255,255,0.08); }

    .action-title {
      display: block;
      font-size: 0.95rem;
      font-weight: 800;
      margin-bottom: 4px;
    }

    .action-sub {
      display: block;
      color: #bfcfe4;
      font-size: 0.76rem;
      line-height: 1.45;
    }

    @keyframes battleHitFlash {
      0% { opacity: 1; filter: brightness(1); }
      18% { opacity: 0.1; filter: brightness(1.75); }
      36% { opacity: 1; filter: brightness(1); }
      54% { opacity: 0.12; filter: brightness(1.85); }
      72% { opacity: 1; filter: brightness(1.15); }
      100% { opacity: 1; filter: brightness(1); }
    }

    .battle-mon.hit {
      animation: battleHitFlash 240ms ease-out 1;
    }


    .battle-mon.enemy,
    .battle-mon.ally {
      opacity: 1 !important;
      filter: none !important;
    }

    @keyframes battleFaintDown {
      0% { opacity: 1; transform: translateY(0); clip-path: inset(0 0 0 0); }
      30% { opacity: 1; transform: translateY(4px); clip-path: inset(0 0 10% 0); }
      62% { opacity: 0.98; transform: translateY(10px); clip-path: inset(0 0 42% 0); }
      82% { opacity: 0.9; transform: translateY(18px); clip-path: inset(0 0 74% 0); }
      100% { opacity: 0; transform: translateY(30px); clip-path: inset(0 0 100% 0); }
    }

    .battle-mon.enemy.fainting {
      animation: battleFaintDown 1850ms ease-in forwards;
    }

    .battle-mon.ally.fainting {
      animation: battleFaintDown 1850ms ease-in forwards;
    }

    .modal-type-chart-image {
      max-width: min(96vw, 980px);
      width: min(96vw, 980px);
    }

    .type-chart-image-body {
      padding: 8px;
      overflow: auto;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      background: rgba(0,0,0,0.18);
      border-radius: 18px;
    }

    .type-chart-reference-image {
      display: block;
      width: min(100%, 920px);
      height: auto;
      border-radius: 18px;
      box-shadow: 0 18px 36px rgba(0,0,0,0.18);
      border: 1px solid rgba(0,0,0,0.08);
      background: #ffffff;
    }

    @media (max-width: 420px) {
      .pokemon-card {
        min-height: 332px;
        padding-right: 58px;
      }
      .move-chip {
        min-width: 52px;
        min-height: 32px;
        font-size: 0.74rem;
      }
      .summary-grid,
      .move-meta-grid,
      .reserve-panel {
        grid-template-columns: 1fr;
      }
      .stat-grid {
        gap: 8px;
      }
      .battle-status-card {
        width: 76%;
      }
    }

    .chip-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 0 14px;
      border-radius: 999px;
      font-size: 0.82rem;
      font-weight: 800;
      color: var(--sky);
      border-color: rgba(126, 207, 255, 0.25);
      background: linear-gradient(180deg, rgba(126, 207, 255, 0.14), rgba(255,255,255,0.06));
    }

    .item-pick.selected {
      border-color: rgba(126, 207, 255, 0.38);
      background: linear-gradient(180deg, rgba(126, 207, 255, 0.12), rgba(255,255,255,0.06));
    }

    .item-title-row {
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:10px;
      margin-bottom:10px;
    }

    .item-title-row h3 {
      margin:0;
      font-size:0.92rem;
      font-weight:800;
    }

    .item-squad-chip {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }

    .item-slot-strip {
      display:grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap:8px;
    }

    .item-slot {
      min-height:34px;
      border-radius:12px;
      border:1px dashed rgba(255,255,255,0.14);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:4px 6px;
      font-size:0.7rem;
      color:var(--text-muted);
      background:rgba(255,255,255,0.03);
      text-align:center;
      line-height:1.2;
    }

    .item-slot.filled {
      border-style:solid;
      color:var(--text-main);
      background:rgba(126,207,255,0.12);
    }



    .starter-screen {
      min-height: 100vh;
      padding: 20px 16px 28px;
      background: radial-gradient(circle at top, rgba(58, 90, 124, .42), rgba(8, 10, 14, 1) 56%), #05070a;
      overflow-y: auto;
    }
    .starter-draft-shell { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: 14px; }
    .starter-logo { margin-top: 12px; }
    .starter-draft-card { background: rgba(19, 23, 31, .96); border: 1px solid rgba(126,207,255,.18); border-radius: 26px; padding: 18px; box-shadow: var(--soft-shadow); display:flex; flex-direction:column; gap:14px; }
    .starter-topline { color: var(--sky); font-size: 12px; font-weight: 800; letter-spacing: .06em; }
    .starter-main-title { margin:0; font-size: 24px; }
    .starter-copy { margin:0; color: var(--text-dim); line-height: 1.55; }
    .starter-summary-row { display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap:8px; }
    .starter-pick-chip { min-height: 44px; border-radius: 14px; border:1px dashed rgba(255,255,255,.14); display:flex; align-items:center; justify-content:center; color: var(--text-dim); background: rgba(255,255,255,.03); font-size:13px; font-weight:700; text-align:center; padding: 0 8px; }
    .starter-pick-chip.filled { border-style: solid; color: var(--text-main); background: rgba(126,207,255,.12); }
    .starter-groups-wrap { display:flex; flex-direction:column; gap:12px; }
    .starter-group { display:flex; flex-direction:column; gap:8px; }
    .starter-group-title { font-size: 15px; font-weight: 800; color: #f2f6ff; }
    .starter-card-grid { display:grid; grid-template-columns: 1fr; gap:10px; }
    .starter-option-card { width:100%; text-align:left; border-radius:18px; border:1px solid rgba(255,255,255,.09); background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03)); padding:14px; color: var(--text-main); display:flex; flex-direction:column; gap:8px; }
    .starter-option-card.selected { border-color: rgba(126,207,255,.85); box-shadow: 0 0 0 1px rgba(126,207,255,.35) inset; background: linear-gradient(180deg, rgba(126,207,255,.18), rgba(255,255,255,.04)); }
    .starter-option-head { display:flex; align-items:center; gap:12px; }
    .starter-option-copy { display:flex; flex-direction:column; gap:4px; min-width:0; }
    .starter-option-name { font-size:16px; font-weight:800; }
    .starter-option-meta { color: var(--text-dim); font-size:12px; display:flex; flex-wrap:wrap; gap:6px; align-items:center; }
    .starter-option-ability { color: #dfeeff; font-size: 12px; font-weight: 700; }
    .starter-option-note { margin:0; color: var(--text-dim); font-size:12px; line-height:1.5; }
    .starter-footer { display:flex; align-items:center; justify-content:space-between; gap:12px; }
    .starter-help { color: var(--text-dim); font-size:13px; }
    .starter-confirm:disabled { opacity:.45; cursor:not-allowed; }
    .ability-row { margin-top: 8px; display:flex; flex-wrap:wrap; gap:6px; align-items:center; font-size: 12px; color: var(--text-dim); }
    .ability-name { color:#f2f6ff; font-weight:800; }
    .hidden-ability-pill { display:inline-flex; align-items:center; padding:4px 8px; border-radius:999px; background: rgba(255,199,94,.14); color:#ffd98a; font-size:11px; font-weight:800; }

  .disabled-ability{opacity:.45;text-decoration:line-through;} .battle-trainer-intro{position:absolute;top:18px;left:50%;transform:translateX(-50%);z-index:8;background:rgba(11,14,20,.78);border:1px solid rgba(255,255,255,.12);border-radius:18px;padding:8px 14px;} .shop-modal .modal-body{backdrop-filter: blur(1px);} .money-text{color:#f6d34a !important;font-weight:800;} .shop-modal,.shop-modal *{color:#111;} .shop-item-card,.shop-tip-card,.shop-section-card{background:rgba(255,255,255,.92)!important;color:#111!important;} .shop-item-meta{font-size:12px;font-weight:700;color:#222!important;} .shop-price{background:#f6d34a;color:#111!important;} </style>
</head>
<body>
  <div class="app-root" id="app-root">
    <section id="title-screen" class="screen title-screen">
      <div class="title-logo" aria-label="POKEBATTLE">
        <span class="poke">POKE</span><span class="battle">BATTLE</span>
      </div>
      <p class="title-subcopy">
        모바일 세로 화면에 최적화된 포켓몬 리그 게임. 싱글플레이 또는 2인플레이로 시작해서 스쿼드를 관리하세요.
      </p>
      <div class="title-actions">
        <button class="hero-button primary" type="button" data-start-mode="single">싱글플레이</button>
        <button class="hero-button" type="button" data-start-mode="duo">2인플레이</button>
              </div>
    </section>



    <section id="starter-screen" class="screen starter-screen hidden" aria-hidden="true"></section>

    <section id="lobby-screen" class="screen lobby-screen hidden" aria-live="polite">
      <header class="top-shell">
        <div class="top-bar">
          <div class="profile-wrap">
            <div id="trainer-avatar" class="trainer-avatar red" aria-hidden="true"></div>
            <div class="profile-copy">
              <div class="trainer-name-row">
                <span id="trainer-name" class="trainer-name red">레드</span>
                <span id="season-label" class="season-label">시즌 1</span>
              </div>
              <span id="mode-label" class="season-label">싱글플레이</span>
            </div>
          </div>
          <div class="top-controls">
            <button id="open-settings-btn" class="mini-icon-btn" type="button" aria-label="설정 열기">⚙️</button>
            <button id="open-chat-btn" class="mini-icon-btn" type="button" aria-label="채팅 열기">💬</button>
          </div>
        </div>

        <div class="top-second-row">
          <div class="mode-pill" id="turn-indicator">현재 확인 중: 레드의 로비</div>
          <div id="trainer-switcher" class="trainer-switcher"></div>
        </div>
      </header>

      <main id="content-area" class="content-scroll"></main>

      <button id="open-type-chart-btn" class="floating-type-button" type="button">타입 상성표</button>

      <nav class="bottom-nav" aria-label="카테고리">
        <button class="nav-btn active" type="button" data-nav="squad"><span class="emoji">🛡️</span><span>스쿼드</span></button>
        <button class="nav-btn" type="button" data-nav="items"><span class="emoji">🎒</span><span>아이템</span></button>
        <button class="nav-btn" type="button" data-nav="league"><span class="emoji">🏆</span><span>리그</span></button>
        <button class="nav-btn" type="button" data-nav="dungeon"><span class="emoji">🌋</span><span>던전</span></button>
      </nav>
    </section>

    <section id="battle-screen" class="screen battle-screen hidden" aria-hidden="true">
      <div class="battle-shell">
        <div class="battle-top">
          <div class="battle-corner-actions">
            <button id="battle-stats-btn" class="battle-corner-btn" type="button">스탯 확인</button>
          </div>
          <div class="battle-status-card enemy">
            <div class="battle-status-head">
              <span id="battle-enemy-name" class="battle-pokemon-name">상대 포켓몬</span>
              <span id="battle-enemy-level" class="battle-level">Lv.5</span><span id="battle-enemy-types" class="battle-types-inline"></span>
            </div>
            <div class="hp-line">
              <div class="hp-bar-wrap"><div id="battle-enemy-bar" class="hp-bar"></div></div>
              <span id="battle-enemy-hp" class="hp-text">20 / 20</span>
            </div>
            <div id="battle-enemy-balls" class="ball-count">● ● ●</div>
          </div>

          <div class="battle-status-card ally">
            <div class="battle-status-head">
              <span id="battle-ally-name" class="battle-pokemon-name">내 포켓몬</span>
              <span id="battle-ally-level" class="battle-level">Lv.5</span><span id="battle-ally-types" class="battle-types-inline"></span>
            </div>
            <div class="hp-line">
              <div class="hp-bar-wrap"><div id="battle-ally-bar" class="hp-bar"></div></div>
              <span id="battle-ally-hp" class="hp-text">20 / 20</span>
            </div>
            <div id="battle-ally-balls" class="ball-count">● ● ●</div>
          </div>

          <div class="battle-scene">
            <div id="battle-enemy-mon" class="battle-mon enemy" style="background:#5a8dee;color:#2f5d9e;"></div>
            <div id="battle-ally-mon" class="battle-mon ally" style="background:#f08030;color:#f8d030;"></div>
          </div>
        </div>

        <div class="battle-bottom">
          <div id="battle-log" class="battle-log">
            배틀 엔진은 아직 연결하지 않았습니다. 다음 단계에서 5세대 기준 턴제 배틀 로직, 데미지 공식, 교체, 아이템 사용이 이 영역과 연결됩니다.
          </div>
          <div id="battle-turn-indicator" class="battle-turn-indicator hidden"></div>
          <div id="battle-action-grid" class="battle-action-grid">
            <button type="button" class="action-button"><span class="action-title">싸운다</span><span class="action-sub">기술 3개 표시 예정</span></button>
            <button type="button" class="action-button"><span class="action-title">가방</span><span class="action-sub">소비 아이템 전용</span></button>
            <button type="button" class="action-button"><span class="action-title">포켓몬</span><span class="action-sub">교체 연동 예정</span></button>
            <button type="button" class="action-button"><span class="action-title">타입 상성표</span><span class="action-sub">공격과 방어 타입 상성을 확인합니다.</span></button>
          </div>
          <button id="battle-type-chart-btn" class="floating-type-button" type="button">타입 상성표</button>
        </div>
      </div>
    </section>
  </div>

  <div id="modal-root"></div>

  <script src="core.js"></script>
  <script src="ui.js"></script>
  <script src="items.js"></script>
  <script src="battle-engine.js"></script>
  <script src="league.js"></script>
  <script src="dungeon.js"></script>
</body>
</html>
