(function () {
  'use strict';

  const POKEBATTLE = window.POKEBATTLE || (window.POKEBATTLE = {});
  const modalRoot = () => document.getElementById('modal-root');

  const uiState = {
    activeModal: null,
    toastTimer: null,
    afterBattleModalClose: null,
    bgmAudio: null,
    currentBgm: null,
    currentPlaylistKey: null,
    playlist: [],
    playlistIndex: 0,
    chatMessages: [],
    battleIntroKey: null,
    battleIntroUntil: 0,
    effectLockUntil: 0
  };

  const MEDIA_ASSETS = {
    '이상해씨': 'starter-sprites/ec.png', '이상해풀': 'starter-sprites/ep.png', '이상해꽃': 'starter-sprites/egg.png',
    '파이리': 'starter-sprites/pr.png', '리자드': 'starter-sprites/rd.png', '리자몽': 'starter-sprites/lm.png',
    '꼬부기': 'starter-sprites/ggb.png', '어니부기': 'starter-sprites/eb.png', '거북왕': 'starter-sprites/gbw.png',
    '나무지기': 'starter-sprites/nj.png', '나무돌이': 'starter-sprites/nd.png', '나무킹': 'starter-sprites/nk.png',
    '모부기': 'starter-sprites/mb.png', '수풀부기': 'starter-sprites/sb.png', '토대부기': 'starter-sprites/tb.png',
    '아차모': 'starter-sprites/ac.png', '영치코': 'starter-sprites/yc.png', '번치코': 'starter-sprites/bc.png',
    '불꽃숭이': 'starter-sprites/bs.png', '파이숭이': 'starter-sprites/ps.png', '초염몽': 'starter-sprites/cy.png',
    '물짱이': 'starter-sprites/mjj.png', '늪짱이': 'starter-sprites/njj.png', '대짱이': 'starter-sprites/djj.png',
    '팽도리': 'starter-sprites/pd.png', '팽태자': 'starter-sprites/pt.png', '엠페르트': 'starter-sprites/emp.png',
    '주리비얀': 'starter-sprites/jb.png', '샤비': 'starter-sprites/syb.png', '샤로다': 'starter-sprites/syr.png',
    '뚜꾸리': 'starter-sprites/ddg.png', '차오꿀': 'starter-sprites/cg.png', '염무왕': 'starter-sprites/ym.png',
    '수댕이': 'starter-sprites/sd.png', '쌍검자비': 'starter-sprites/ssg.png', '대검귀': 'starter-sprites/dg.png',
    '아르세우스': 'skin-sprites/arc.png', '불비달마': 'skin-sprites/bbdm.png', '크로뱃': 'skin-sprites/crb.png',
    '칠색조': 'skin-sprites/csj.png', '다크라이': 'skin-sprites/dk.png', '디아루가': 'skin-sprites/drg.png',
    '에레키블': 'skin-sprites/erk.png', '액스라이즈': 'skin-sprites/exr.png', '가이오가': 'skin-sprites/gga.png',
    '게노세크트': 'skin-sprites/gnc.png', '그란돈': 'skin-sprites/grd.png', '갸라도스': 'skin-sprites/grds.png',
    '기라티나': 'skin-sprites/grt.png', '한카리아스': 'skin-sprites/hcr.png', '화강돌': 'skin-sprites/hgd.png',
    '제크로무': 'skin-sprites/jcr.png', '전룡': 'skin-sprites/jr.png', '마기라스': 'skin-sprites/mgr.png',
    '망나뇽': 'skin-sprites/mnn.png', '밀로틱': 'skin-sprites/mrt.png', '뮤츠': 'skin-sprites/mtz.png',
    '파비코리': 'skin-sprites/pbc.png', '펄기아': 'skin-sprites/pga.png', '피카츄': 'skin-sprites/pkc.png',
    '포푸니라': 'skin-sprites/ppnr.png', '루기아': 'skin-sprites/rga.png', '레쿠쟈': 'skin-sprites/rkj.png',
    '루카리오': 'skin-sprites/rkr.png', '레시라무': 'skin-sprites/rsrm.png', '라이츄': 'skin-sprites/rych.png',
    '라이코': 'skin-sprites/ryk.png', '쉐이미': 'skin-sprites/shm.png', '삼삼드래': 'skin-sprites/ssd.png',
    '스이쿤': 'skin-sprites/syc.png',
    '아보크': 'skin2-sprites/arbok.png', '깨비드릴조': 'skin2-sprites/fearow.png', '자포코일': 'skin2-sprites/magnezone.png',
    '나인테일': 'skin2-sprites/ninetales.png', '피죤투': 'skin2-sprites/pidgeot.png', '램펄드': 'skin2-sprites/rampardos.png',
    '로즈레이드': 'skin2-sprites/roserade.png', '찌르호크': 'skin2-sprites/staraptor.png',
    '후딘': 'skin3-sprites/alakazam.png', '크레베이스': 'skin3-sprites/avalugg.png', '둥실라이드': 'skin3-sprites/drifblim.png',
    '가디안': 'skin3-sprites/gardevoir.png', '맘모꾸리': 'skin3-sprites/mamoswine.png', '펜드라': 'skin3-sprites/scolipede.png', '고릴타': 'skin3-sprites/rillaboom.png',
    '윈디': 'skin4-sprites/arcanine.png', '괴력몬': 'skin4-sprites/machamp.png', '라프라스': 'skin4-sprites/lapras.png', '핫삼': 'skin4-sprites/scizor.png',
    '헤라크로스': 'skin4-sprites/heracross.png', '얼음귀신': 'skin4-sprites/glalie.png', '야느와르몽': 'skin4-sprites/dusknoir.png', '페르시안': 'skin4-sprites/persian.png',
    '페르시온': 'skin4-sprites/persian.png', '나옹': 'skin4-sprites/meowth.png',
    '메가루카리오': { type: 'video', src: 'media-videos/mega_lucario.mp4', poster: 'skin-sprites/rkr.png' },
    '메가피죤투': { type: 'video', src: 'media-videos/mega_pidgeot.mp4', poster: 'skin2-sprites/pidgeot.png' },
    '메가전룡': { type: 'video', src: 'media-videos/mega_ampharos.mp4', poster: 'skin-sprites/jr.png' },
    '메가레쿠쟈': { type: 'video', src: 'media-videos/mega_rayquaza.mp4', poster: 'skin-sprites/rkj.png' },
    '메가가디안': { type: 'video', src: 'media-videos/mega_gardevoir.mp4', poster: 'skin3-sprites/gardevoir.png' },
    '메가헤라크로스': { type: 'video', src: 'media-videos/mega_heracross.mp4', poster: 'skin4-sprites/heracross.png' },
    '다크라이': { type: 'video', src: 'media-videos/darkrai.mp4', poster: 'skin-sprites/dk.png' },
    '기라티나': { type: 'video', src: 'media-videos/giratina.mp4', poster: 'skin-sprites/grt.png' },
    '포푸니라': { type: 'video', src: 'media-videos/weavile.mp4', poster: 'skin-sprites/ppnr.png' }
  };

  function getPokemonMedia(base) {
    const mediaKey = base?.mediaNameKo || base?.nameKo;
    const asset = MEDIA_ASSETS[mediaKey];
    if (!asset) return null;
    if (typeof asset === 'string') return { type: 'image', src: asset };
    return asset;
  }

  const TYPE_CHART_DATA_URI = 'data:image/png;base64,';

  function init() {
    injectRuntimeStyles();
    renderTrainerSwitcher();
    const chatButton = document.getElementById('open-chat-btn');
    if (chatButton && !chatButton.dataset.boundChat) {
      chatButton.dataset.boundChat = '1';
      chatButton.addEventListener('click', () => openChatModal());
    }
  }

  function showScreen(screen) {
    const focused = document.activeElement;
    if (focused && typeof focused.blur === 'function') focused.blur();
    ['title', 'starter', 'lobby', 'battle'].forEach((key) => {
      const node = document.getElementById(`${key}-screen`);
      if (!node) return;
      const hidden = key !== screen;
      node.classList.toggle('hidden', hidden);
      node.setAttribute('aria-hidden', hidden ? 'true' : 'false');
      if (hidden) node.setAttribute('inert', '');
      else node.removeAttribute('inert');
    });
  }

  function ensureBgmAudio() {
    if (uiState.bgmAudio) return uiState.bgmAudio;
    uiState.bgmAudio = new Audio();
    uiState.bgmAudio.loop = false;
    uiState.bgmAudio.preload = 'auto';
    uiState.bgmAudio.volume = Number(POKEBATTLE.core?.state?.settings?.bgmVolume ?? 0.7);
    uiState.bgmAudio.addEventListener('ended', () => {
      if (!uiState.playlist || uiState.playlist.length <= 1) return;
      uiState.playlistIndex = (uiState.playlistIndex + 1) % uiState.playlist.length;
      const nextSrc = uiState.playlist[uiState.playlistIndex];
      uiState.currentBgm = nextSrc;
      uiState.bgmAudio.src = nextSrc;
      applyBgmOffset(uiState.bgmAudio, nextSrc);
      uiState.bgmAudio.load();
      const playPromise = uiState.bgmAudio.play();
      if (playPromise && typeof playPromise.catch === 'function') playPromise.catch(() => {});
    });
    return uiState.bgmAudio;
  }

  function syncBgmVolume() {
    const audio = ensureBgmAudio();
    const volume = Math.max(0, Math.min(1, Number(POKEBATTLE.core?.state?.settings?.bgmVolume ?? 0.7) || 0));
    audio.volume = volume;
    audio.muted = volume <= 0;
    return volume;
  }

  function applyBgmOffset(audio, src) {
    const normalized = String(src || '').trim();
    if (normalized !== 'enter_darkrai.mp3') return;
    const seekToOffset = () => {
      try {
        if (audio.duration && Number.isFinite(audio.duration) && audio.duration > 4) audio.currentTime = 4;
      } catch (error) {}
    };
    audio.addEventListener('loadedmetadata', seekToOffset, { once: true });
    audio.addEventListener('canplay', seekToOffset, { once: true });
  }

  function playEffectSound(src, delay = 0) {
    const action = () => {
      const normalized = String(src || '').trim();
      const isBattleEnd = ['battle_win.mp3', 'fail.mp3'].includes(normalized);
      const resumeDelay = normalized === 'battle_win.mp3' ? 7050 : 1750;
      if (isBattleEnd) {
        uiState.effectLockUntil = Date.now() + resumeDelay;
        stopBackgroundMusic();
        setTimeout(() => syncBackgroundMusic(POKEBATTLE.core?.state?.currentScreen || 'lobby'), resumeDelay);
      }
      const audio = new Audio(normalized);
      audio.preload = 'auto';
      audio.volume = Math.max(0, Math.min(1, Number(POKEBATTLE.core?.state?.settings?.bgmVolume ?? 0.7) || 0));
      if (normalized === 'battle_win.mp3') {
        setTimeout(() => {
          try { audio.pause(); audio.currentTime = 0; } catch (error) {}
        }, 7000);
      }
      audio.play().catch(() => {});
    };
    if (delay > 0) setTimeout(action, delay); else action();
  }

  function stopBackgroundMusic() {
    const audio = uiState.bgmAudio;
    if (!audio) return;
    audio.pause();
    uiState.currentBgm = null;
  }

  function syncBackgroundMusic(screen) {
    if (Date.now() < Number(uiState.effectLockUntil || 0)) return;
    const battleSnapshot = POKEBATTLE.battleEngine?.getSnapshot?.();
    let playlist = [];
    let key = screen;
    if (screen === 'battle') {
      const special = battleSnapshot?.specialBgm || null;
      if (special) playlist = [special];
      else if (['route', 'dungeon_route'].includes(battleSnapshot?.theme)) playlist = ['hgssrival.mp3'];
      else if (['galaxy', 'dungeon_galaxy'].includes(battleSnapshot?.theme)) playlist = ['team_galactic.mp3'];
      else if (['distortion', 'dungeon_distortion'].includes(battleSnapshot?.theme)) playlist = ['dungeon.mp3'];
      else playlist = ['battle.mp3'];
      key += ':' + (playlist[0] || 'battle.mp3');
    } else if (screen === 'starter' || screen === 'lobby') {
      playlist = ['route_201.mp3','forest.mp3'];
      key = 'lobby-rotation';
    } else {
      stopBackgroundMusic();
      return;
    }
    const audio = ensureBgmAudio();
    syncBgmVolume();
    if (uiState.currentPlaylistKey !== key) {
      uiState.currentPlaylistKey = key;
      uiState.playlist = playlist.slice();
      uiState.playlistIndex = 0;
      uiState.currentBgm = uiState.playlist[0] || null;
      audio.src = uiState.currentBgm || '';
      applyBgmOffset(audio, uiState.currentBgm);
      audio.load();
      audio.play().catch(() => {});
      return;
    }
    if (!audio.src && uiState.playlist.length) {
      uiState.currentBgm = uiState.playlist[uiState.playlistIndex];
      audio.src = uiState.currentBgm;
      applyBgmOffset(audio, uiState.currentBgm);
      audio.load();
      audio.play().catch(() => {});
    }
  }

  function renderAll() {
    const core = POKEBATTLE.core;
    if (!core) return;
    showScreen(core.state.currentScreen);
    syncBackgroundMusic(core.state.currentScreen);
    renderStarterDraft();
    renderLobbyHeader();
    renderTrainerSwitcher();
    renderBottomNav();
    renderCurrentCategory();
    renderBattle();
  }



  function renderStarterDraft() {
    const core = POKEBATTLE.core;
    const screen = document.getElementById('starter-screen');
    if (!core || !screen) return;
    const draft = core.getStarterDraftState?.();
    if (!draft) return;
    const activeId = draft.activePlayerId || 'p1';
    const playerName = activeId === 'p1' ? '레드' : '그린';
    const selections = draft.selections?.[activeId] || [];
    const groups = (draft.starterPool || []).map((group) => `
      <section class="starter-group">
        <div class="starter-group-title">${escapeHtml(group.generation)}</div>
        <div class="starter-card-grid">
          ${group.pokemon.map((pokemon) => renderStarterOptionCard(pokemon, selections)).join('')}
        </div>
      </section>
    `).join('');
    const summary = selections.map((id, index) => {
      const pokemon = core.state.pokemonById.get(id);
      return `<div class="starter-pick-chip ${pokemon ? 'filled' : ''}">${pokemon ? `${index + 1}. ${escapeHtml(pokemon.nameKo)}` : `${index + 1}. 비어 있음`}</div>`;
    }).join('') + Array.from({ length: Math.max(0, 3 - selections.length) }).map((_, idx) => `<div class="starter-pick-chip">${selections.length + idx + 1}. 비어 있음</div>`).join('');

    screen.innerHTML = `
      <div class="starter-draft-shell">
        <div class="title-logo starter-logo" aria-label="POKEBATTLE">
          <span class="poke">POKE</span><span class="battle">BATTLE</span>
        </div>
        <div class="starter-draft-card">
          <div class="starter-topline">${draft.mode === 'duo' ? '2인플레이 스타팅 선택' : '싱글플레이 스타팅 선택'}</div>
          <h1 class="starter-main-title">${playerName}의 시작 포켓몬 3마리를 골라줘</h1>
          <p class="starter-copy">스타팅 포켓몬 중 원하는 3마리를 선택하면 시작할 수 있어.</p>
          <div class="starter-summary-row">${summary}</div>
          <div class="starter-groups-wrap">${groups}</div>
          <div class="starter-footer">
            <span class="starter-help">선택 수: ${selections.length} / 3</span>
            <button type="button" class="hero-button primary starter-confirm" id="starter-confirm-btn" ${selections.length === 3 ? '' : 'disabled'}>${draft.mode === 'duo' && activeId === 'p1' ? '그린 선택으로 이동' : '선택 완료하고 시작'}</button>
          </div>
        </div>
      </div>
    `;
    screen.querySelectorAll('[data-starter-id]').forEach((button) => {
      button.addEventListener('click', () => core.toggleStarterChoice(button.dataset.starterId));
    });
    const confirm = document.getElementById('starter-confirm-btn');
    if (confirm) confirm.addEventListener('click', () => core.finalizeStarterDraft());
  }

  function renderStarterOptionCard(pokemon, selections) {
    const selected = selections.includes(pokemon.id);
    const types = (pokemon.type || []).map(renderTypeBadge).join('');
    const abilityLine = pokemon.hiddenAbility
      ? `${escapeHtml(pokemon.ability || '-') } · 숨겨진 특성 ${escapeHtml(pokemon.hiddenAbility)}`
      : escapeHtml(pokemon.ability || '-');
    return `
      <button type="button" class="starter-option-card ${selected ? 'selected' : ''}" data-starter-id="${pokemon.id}">
        <div class="starter-option-head">
          <div class="avatar-shell small">${renderAvatar(pokemon, '56')}</div>
          <div class="starter-option-copy">
            <div class="starter-option-name">${escapeHtml(pokemon.nameKo)}</div>
            <div class="starter-option-meta">Lv.5 시작 · ${types}</div>
          </div>
        </div>
        <div class="starter-option-ability">특성: ${abilityLine}</div>
        <div class="starter-option-note">${escapeHtml(pokemon.battleNote || '')}</div>
      </button>
    `;
  }

  function renderLobbyHeader() {
    const core = POKEBATTLE.core;
    const activePlayer = core.getActivePlayer();
    if (!activePlayer) return;

    const trainerName = document.getElementById('trainer-name');
    const trainerAvatar = document.getElementById('trainer-avatar');
    const seasonLabel = document.getElementById('season-label');
    const modeLabel = document.getElementById('mode-label');
    const turnIndicator = document.getElementById('turn-indicator');

    if (trainerName) {
      trainerName.textContent = activePlayer.name;
      trainerName.className = `trainer-name ${activePlayer.id === 'p1' ? 'red' : 'green'}`;
    }
    if (trainerAvatar) trainerAvatar.className = `trainer-avatar ${activePlayer.id === 'p1' ? 'red' : 'green'}`;
    if (seasonLabel) seasonLabel.textContent = `시즌 ${core.state.season}`;
    if (modeLabel) modeLabel.textContent = core.state.gameMode === 'duo' ? '2인플레이' : '싱글플레이';
    if (turnIndicator) {
      turnIndicator.textContent = core.state.gameMode === 'duo'
        ? `현재 확인 중: ${activePlayer.name}의 로비`
        : '현재 확인 중: 레드의 로비';
    }
  }

  function renderTrainerSwitcher() {
    const core = POKEBATTLE.core;
    const wrap = document.getElementById('trainer-switcher');
    if (!core || !wrap) return;
    const buttons = [
      { id: 'p1', label: '레드' },
      { id: 'p2', label: '그린' }
    ].filter((entry) => core.state.gameMode === 'duo' || entry.id === 'p1');

    wrap.innerHTML = buttons.map((entry) => `
      <button
        type="button"
        class="trainer-toggle ${core.state.activePlayerId === entry.id ? 'active' : ''}"
        data-player-switch="${entry.id}">
        ${entry.label}
      </button>
    `).join('');

    wrap.querySelectorAll('[data-player-switch]').forEach((button) => {
      button.addEventListener('click', () => core.setActivePlayer(button.dataset.playerSwitch));
    });
  }

  function renderBottomNav() {
    const core = POKEBATTLE.core;
    document.querySelectorAll('[data-nav]').forEach((button) => {
      const active = button.dataset.nav === core.state.currentCategory;
      button.classList.toggle('active', active);
      button.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
  }

  function renderCurrentCategory() {
    const core = POKEBATTLE.core;
    const contentArea = document.getElementById('content-area');
    if (!contentArea) return;
    if (core.state.currentCategory === 'squad') {
      contentArea.innerHTML = renderSquadCategory();
      bindSquadInteractions();
      return;
    }
    if (core.state.currentCategory === 'items') {
      contentArea.innerHTML = renderItemsCategory();
      bindItemsInteractions();
      return;
    }
    if (core.state.currentCategory === 'league') {
      contentArea.innerHTML = POKEBATTLE.league?.renderCategory ? POKEBATTLE.league.renderCategory() : renderLeaguePlaceholder();
      bindLeagueInteractions();
      return;
    }
    contentArea.innerHTML = POKEBATTLE.dungeon?.renderCategory ? POKEBATTLE.dungeon.renderCategory() : renderDungeonPlaceholder();
    bindDungeonInteractions();
  }

  function renderSquadCategory() {
    const core = POKEBATTLE.core;
    const player = core.getActivePlayer();
    const bestStats = core.getBestStatKeys(player);
    const squadCards = player.squad.map((pokemon, index) => renderPokemonCard(player, pokemon, index, bestStats, 'squad')).join('');
    const reserve = player.reserve.length
      ? player.reserve.map((pokemon) => renderReserveChip(player, pokemon)).join('')
      : `<div class="empty-state">아직 보유 포켓몬이 없습니다. 현재 단계에서는 시작 포켓몬 3마리만 배정되어 있습니다.</div>`;

    return `
      <section class="panel-card">
        <div class="section-title-row">
          <div>
            <h1 class="section-title" style="font-size:1.22em;">🛡️ 스쿼드</h1>
            <p class="section-caption" style="font-size:1.08em;">메인 포켓몬 3마리는 배틀에 출전합니다. 로비화면에서는 메인 포켓몬들을 추후 보유 포켓몬과 위치를 교체할 수 있습니다.</p>
          </div>
        </div>

        <div class="info-banner"><strong>숨겨진 특성 규칙</strong> 메인 포켓몬 목록에서 최종 진화 전 스타팅 포켓몬이 보유한 스타팅 포켓몬들 중에서만 가장 위에 위치하면 최종 진화 시 숨겨진 특성 획득.</div>
        <div class="info-banner"><strong>메가진화</strong> 레벨 90 이상이라면 메가진화포켓몬으로 변합니다. 메가진화 포켓몬: 라프라스, 전룡, 라이츄, 피존투, 핫삼, 헤라크로스, 레쿠쟈</div>

        <div class="squad-grid">${squadCards}</div>

        <div class="subsection">
          <div class="subheading">
            <h3>보유 포켓몬 명단</h3>
            <span>아래 목록은 1/3 공간 역할을 하는 보관 영역입니다.</span>
          </div>
          <div class="reserve-panel">${reserve}</div>
        </div>
      </section>
    `;
  }


  function getHeldItemsForDisplay(runtimePokemon) {
    if (Array.isArray(runtimePokemon?.heldItems) && runtimePokemon.heldItems.length) return runtimePokemon.heldItems.filter(Boolean);
    if (runtimePokemon?.heldItem) return [runtimePokemon.heldItem];
    return [];
  }

  function getHeldItemDisplayStats(runtimePokemon) {
    const stats = { ...(runtimePokemon?.stats || {}) };
    const itemsApi = POKEBATTLE.items;
    stats.attack = Math.max(1, Math.floor(Number(stats.attack || 1) * (itemsApi?.getAttackMultiplier?.(runtimePokemon, { category: '물리' }) || 1)));
    stats.spAttack = Math.max(1, Math.floor(Number(stats.spAttack || 1) * (itemsApi?.getSpecialAttackMultiplier?.(runtimePokemon, { category: '특수' }) || 1)));
    stats.speed = Math.max(1, Math.floor(Number(stats.speed || 1) * (itemsApi?.getSpeedMultiplier?.(runtimePokemon) || 1)));
    return stats;
  }

  function renderPokemonCard(player, runtimePokemon, index, bestStats, slotType) {
    const core = POKEBATTLE.core;
    const state = core.state;
    const base = runtimePokemon.base;
    const selected = Boolean(state.selectedSwap && state.selectedSwap.playerId === player.id && state.selectedSwap.type === slotType && state.selectedSwap.uid === runtimePokemon.uid);
    const types = (runtimePokemon.currentTypes || []).map(renderTypeBadge).join('');
    const displayStats = getHeldItemDisplayStats(runtimePokemon);
    const stats = core.state.statsMeta.map(({ key, label }) => {
      const value = Number(displayStats[key] || 0);
      const isBest = value === bestStats[key];
      return `
        <div class="stat-box">
          <span class="stat-label">${label}</span>
          <span class="stat-value ${isBest ? 'is-best' : ''}">${value}</span>
        </div>
      `;
    }).join('') || '<div class="empty-state">아직 보유한 지닌물건이 없습니다. 프렌들리숍에서 구매해 주세요.</div>';

    const heldItems = getHeldItemsForDisplay(runtimePokemon);
    const heldItem = heldItems.length
      ? heldItems.map((item) => `<span class="held-item"><span class="held-shape" style="background:${escapeHtml(item.colorA || '#7ecfff')};"></span>${escapeHtml(item.nameKo)}</span>`).join('')
      : '';
    const heldEffectNote = heldItems.length
      ? `<div class="battle-note" style="margin-top:6px;color:#ffd47a;">지닌물건 효과: ${heldItems.map((item) => escapeHtml(item.battleEffect || item.description || item.nameKo)).join(' / ')}</div>`
      : '';

    const starterFlag = Boolean(runtimePokemon.starterHiddenCandidate || runtimePokemon.base?.hiddenAbility);
    const hiddenVisible = Boolean(runtimePokemon.useHiddenAbility && runtimePokemon.hiddenAbility);
    const abilityMarkup = runtimePokemon.useHiddenAbility
      ? `특성: <span class="ability-name disabled-ability">${escapeHtml(runtimePokemon.visibleAbility || base.ability || '없음')}</span> <span class="ability-name">${escapeHtml(runtimePokemon.hiddenAbility || runtimePokemon.ability || '없음')}</span><span class="hidden-ability-pill">숨겨진 특성 적용</span>`
      : `특성: <span class="ability-name">${escapeHtml(runtimePokemon.ability || runtimePokemon.visibleAbility || base.ability || '없음')}</span>`;
    return `
      <button
        type="button"
        class="pokemon-card ${selected ? 'selected' : ''}"
        data-select-kind="${slotType}"
        data-select-uid="${runtimePokemon.uid}">
        <div class="pokemon-head">
          <div class="avatar-shell">${renderAvatar(base)}</div>
          <div class="pokemon-copy">
            <div class="name-line">
              <span class="pokemon-name">${index + 1}. ${escapeHtml(runtimePokemon.currentName)}</span>
              <span class="pokemon-level">Lv.${runtimePokemon.level}</span>
              ${heldItem}
            </div>
            <div class="type-row">${types}</div>
          </div>
        </div>
        <div class="stat-grid">${stats}</div>
        <div class="ability-row">${abilityMarkup}</div>
        ${heldEffectNote}
        <p class="battle-note battle-note-emphasis">${highlightPokemonNameText(base.battleNote || '설명이 준비되지 않았습니다.', runtimePokemon.currentName)}</p>
        <div class="card-action-area">
          <button type="button" class="move-chip" data-open-moves="${runtimePokemon.uid}">기술</button>
          <button type="button" class="move-chip" data-open-ability="${runtimePokemon.uid}">특성</button>
        </div>
      </button>
    `;
  }

  function renderReserveChip(player, runtimePokemon) {
    const core = POKEBATTLE.core;
    const state = core.state;
    const selected = Boolean(state.selectedSwap && state.selectedSwap.playerId === player.id && state.selectedSwap.type === 'reserve' && state.selectedSwap.uid === runtimePokemon.uid);
    return `
      <button type="button" class="reserve-chip ${selected ? 'selected' : ''}" data-select-kind="reserve" data-select-uid="${runtimePokemon.uid}">
        ${renderAvatar(runtimePokemon.base, '40')}
        <div class="reserve-copy">
          <span class="reserve-name">${escapeHtml(runtimePokemon.currentName)}</span>
          <span class="reserve-meta">Lv.${runtimePokemon.level} · ${(runtimePokemon.currentTypes || []).join(' / ')}</span>
        </div>
      </button>
    `;
  }

  function renderItemsCategory() {
    const core = POKEBATTLE.core;
    const player = core.getActivePlayer();
    const holdables = core.getHoldableInventory ? core.getHoldableInventory(core.state.activePlayerId) : []; 
    const holdableCards = holdables.map((item) => {
      const selected = core.state.selectedItemId === item.id;
      return `
        <button type="button" class="placeholder-card item-pick ${selected ? 'selected' : ''}" data-select-item="${item.id}">
          <div class="item-title-row">
            <div class="held-item"><span class="held-shape" style="background:${escapeHtml(item.colorA)};"></span>${escapeHtml(item.nameKo)} × ${Number(item.amount || 0)}</div>
            <span class="mini-badge">랭킹 ${item.rank}</span>
          </div>
          <p>${escapeHtml(item.battleEffect || item.description || '')}</p>
        </button>
      `;
    }).join('') || '<div class="empty-state">아직 보유한 지닌물건이 없습니다. 프렌들리숍에서 구매해 주세요.</div>';

    const consumables = player.bag.consumables.map((item) => {
      const selected = core.state.selectedItemId === item.id;
      return `
      <button type="button" class="placeholder-card item-pick ${selected ? 'selected' : ''}" data-select-item="${item.id}">
        <div class="item-title-row"><h3>${escapeHtml(item.nameKo)} × ${item.amount}</h3><span class="mini-badge">${escapeHtml(item.category)}</span></div>
        <p>${escapeHtml(item.description)}</p>
      </button>
    `;
    }).join('');

    const interactSquad = player.squad.map((pokemon, index) => {
      const heldItems = getHeldItemsForDisplay(pokemon);
      const held = heldItems[0] || null;
      return `
        <button type="button" class="reserve-chip item-squad-chip" data-item-target="${pokemon.uid}">
          ${renderAvatar(pokemon.base, '44')}
          <div class="reserve-copy">
            <span class="reserve-name">${index + 1}. ${escapeHtml(pokemon.currentName)}</span>
            <span class="reserve-meta">${held ? escapeHtml(held.nameKo) : '장착 없음'}</span>
          </div>
          <div class="item-slot-strip">
            ${[0, 1].map((slotIndex) => `<span class="item-slot ${heldItems[slotIndex] ? 'filled' : ''}">${heldItems[slotIndex] ? escapeHtml(heldItems[slotIndex].nameKo) : ''}</span>`).join('')}
          </div>
        </button>
      `;
    }).join('');

    return `
      <section class="panel-card">
        <div class="section-title-row">
          <div>
            <h1 class="section-title" style="color:#f6d34a;font-size:1.22em;">🎒 아이템</h1>
            <p class="section-caption" style="font-size:1.08em;">지닌물건을 선택한 뒤 메인 포켓몬을 터치하면 장착됩니다. 포켓몬을 다시 터치하면 해제됩니다. 소비 아이템은 배틀 중 가방 메뉴에서 사용합니다.</p><p class="section-caption">보유 재화: <span class="money-text">$${player.money || 0}</span></p>
          </div>
          <button type="button" class="chip-btn" id="open-friendly-shop-btn" style="color:#ff9c43;font-weight:800;">프렌들리숍</button>
        </div>

        <div class="subsection">
          <div class="subheading"><h3 style="color:#f6d34a;">지닌물건</h3><span>${core.state.selectedItemId ? '선택 완료' : '하나를 선택해 장착'}</span></div>
          <div class="placeholder-stack">${holdableCards}</div>
        </div>

        <div class="subsection">
          <div class="subheading"><h3 style="color:#f6d34a;">소비 아이템 / 특수 도구</h3><span>이상한사탕은 선택 후 포켓몬을 터치하면 즉시 사용</span></div>
          <div class="placeholder-stack">${consumables}</div>
        </div>

        <div class="subsection">
          <div class="subheading"><h3 style="color:#f6d34a;">메인 스쿼드 아이템 장착</h3><span>지닌물건 선택 후 포켓몬을 터치</span></div>
          <div class="placeholder-stack">${interactSquad}</div>
        </div>
      </section>
    `;
  }

  function renderLeaguePlaceholder() {
    return `
      <section class="panel-card">
        <div class="section-title-row">
          <div>
            <h1 class="section-title">🏆 리그</h1>
            <p class="section-caption">리그 일정과 통계는 다음 단계에서 연결됩니다. 현재는 배틀 엔진과 아이템 시스템만 구현했습니다.</p>
          </div>
        </div>
        <div class="placeholder-stack">
          <div class="placeholder-card"><h3>다음 단계 예정</h3><p>매치 편성, 순위표, 트레이너 순위, 포켓몬 통계가 이 영역에 들어갑니다.</p></div>
        </div>
      </section>
    `;
  }

  function renderDungeonPlaceholder() {
    const rewards = Array.isArray(POKEBATTLE.dungeon?.rewardPool) ? POKEBATTLE.dungeon.rewardPool : [];
    return `
      <section class="panel-card">
        <div class="section-title-row">
          <div>
            <h1 class="section-title">🌋 던전</h1>
            <p class="section-caption">던전 입장과 보상 시스템은 아직 만들지 않았습니다.</p>
          </div>
        </div>
        <div class="placeholder-stack">
          <div class="placeholder-card"><h3>현재 상태</h3><p>던전 화면 자리를 유지하고 있습니다. 다음 단계에서 보상과 배틀 연결이 추가됩니다.</p></div>
          <div class="placeholder-card"><h3>예정 보상</h3><p>${rewards.length ? escapeHtml(rewards.join(' · ')) : '배틀도구 보상이 준비되지 않았습니다.'}</p></div>
        </div>
      </section>
    `;
  }

  function bindSquadInteractions() {
    const core = POKEBATTLE.core;
    const contentArea = document.getElementById('content-area');
    if (!contentArea) return;

    contentArea.querySelectorAll('[data-select-kind]').forEach((button) => {
      button.addEventListener('click', (event) => {
        if (event.target.closest('[data-open-moves]')) return;
        core.resolveSelection(button.dataset.selectKind, button.dataset.selectUid);
      });
    });

    contentArea.querySelectorAll('[data-open-moves]').forEach((button) => {
      button.addEventListener('click', (event) => {
        event.stopPropagation();
        const player = core.getActivePlayer();
        const runtimePokemon = [...player.squad, ...player.reserve].find((pokemon) => pokemon.uid === button.dataset.openMoves);
        if (runtimePokemon) openMovesModal(runtimePokemon);
      });
    });

    contentArea.querySelectorAll('[data-open-ability]').forEach((button) => {
      button.addEventListener('click', (event) => {
        event.stopPropagation();
        const player = core.getActivePlayer();
        const runtimePokemon = [...player.squad, ...player.reserve].find((pokemon) => pokemon.uid === button.dataset.openAbility);
        if (runtimePokemon) openAbilityModal(runtimePokemon);
      });
    });
  }

  function bindItemsInteractions() {
    const core = POKEBATTLE.core;
    const contentArea = document.getElementById('content-area');
    if (!contentArea) return;
    contentArea.querySelectorAll('[data-select-item]').forEach((button) => {
      button.addEventListener('click', () => core.selectItem(button.dataset.selectItem));
    });
    contentArea.querySelectorAll('[data-item-target]').forEach((button) => {
      button.addEventListener('click', () => core.toggleHeldItem(button.dataset.itemTarget));
    });
    contentArea.querySelectorAll('#open-friendly-shop-btn').forEach((button) => {
      button.addEventListener('click', () => openFriendlyShopModal());
    });
  }


  function bindLeagueInteractions() {
    const contentArea = document.getElementById('content-area');
    if (!contentArea) return;
    contentArea.querySelectorAll('[data-league-start]').forEach((button) => {
      button.addEventListener('click', () => {
        POKEBATTLE.league?.startNextMatch?.();
      });
    });
    contentArea.querySelectorAll('[data-league-nav]').forEach((button) => {
      button.addEventListener('click', () => {
        POKEBATTLE.league?.navMatch?.(button.dataset.leagueNav);
        renderAll();
      });
    });
    contentArea.querySelectorAll('[data-dismiss-helper]').forEach((button) => {
      button.addEventListener('click', () => {
        POKEBATTLE.core?.markHelperSeen?.(button.dataset.dismissHelper);
        renderAll();
      });
    });
  }


  function bindDungeonInteractions() {
    const contentArea = document.getElementById('content-area');
    if (!contentArea) return;
    POKEBATTLE.dungeon?.bindCategory?.(contentArea);
  }

  function renderBattle() {
    const screen = document.getElementById('battle-screen');
    if (!screen || screen.classList.contains('hidden')) return;
    const engine = POKEBATTLE.battleEngine;
    if (!engine?.ready || !engine.getSnapshot) return;
    const snap = engine.getSnapshot();
    if ((!snap.ally || !snap.enemy) && !(snap.log || []).length) return;

    if (snap.enemy) renderBattleStatusCard('enemy', snap.enemy);
    if (snap.ally) renderBattleStatusCard('ally', snap.ally);
    screen.dataset.battleTheme = snap.theme || '';


    const enemyMon = document.getElementById('battle-enemy-mon');
    const allyMon = document.getElementById('battle-ally-mon');
    if (snap.enemy && enemyMon) enemyMon.outerHTML = renderBattleMonMarkup('battle-enemy-mon', 'battle-mon enemy', snap.enemy.base, 150);
    if (snap.ally && allyMon) allyMon.outerHTML = renderBattleMonMarkup('battle-ally-mon', 'battle-mon ally', snap.ally.base, 150);

    const logNode = document.getElementById('battle-log');
    if (logNode) {
      const lines = snap.log.slice(-3).map((entry) => `<div class="battle-log-entry">${escapeHtml(entry)}</div>`).join('');
      logNode.innerHTML = lines || `<div class="battle-log-entry">배틀이 시작되면 상황이 여기에 표시됩니다.</div>`;
    }

    const turnNode = document.getElementById('battle-turn-indicator');
    if (turnNode) {
      const showTurn = Boolean(snap.turnLabel);
      turnNode.textContent = showTurn ? snap.turnLabel : '';
      turnNode.classList.toggle('hidden', !showTurn);
      turnNode.classList.toggle('red', snap.turnLabel?.includes('레드'));
      turnNode.classList.toggle('green', snap.turnLabel?.includes('그린'));
    }

    const actions = document.getElementById('battle-action-grid');
    if (actions) actions.innerHTML = snap.active ? renderBattleActions(snap) : '<div class="battle-log-entry">배틀이 종료되었습니다.</div>';
    if (snap.active) bindBattleActions();

    const introNode = document.getElementById('battle-trainer-intro');
    if (introNode) {
      const src = snap.trainerIntroSrc;
      const introKey = `${snap.battleId || 'battle'}:${src || ''}`;
      if (!src) {
        introNode.classList.add('hidden');
        introNode.innerHTML = '';
        uiState.battleIntroKey = null;
        uiState.battleIntroUntil = 0;
      } else {
        if (uiState.battleIntroKey !== introKey) {
          uiState.battleIntroKey = introKey;
          uiState.battleIntroUntil = Date.now() + 1000;
          introNode.innerHTML = `<img src="${src}" alt="trainer intro" style="max-height:160px;object-fit:contain;">`;
        }
        const introActive = Date.now() < Number(uiState.battleIntroUntil || 0);
        introNode.classList.toggle('hidden', !introActive);
        const enemyMonNode = document.getElementById('battle-enemy-mon');
        const allyMonNode = document.getElementById('battle-ally-mon');
        [enemyMonNode, allyMonNode].forEach((node) => {
          if (!node) return;
          node.style.opacity = introActive ? '0' : '1';
          node.style.visibility = introActive ? 'hidden' : 'visible';
        });
      }
    }
    const effects = typeof engine.consumeUiEffects === 'function' ? engine.consumeUiEffects() : [];
    effects.forEach((effect) => {
      if (effect.type === 'hit') flashBattleMon(effect.target);
      if (effect.type === 'faint') faintBattleMon(effect.target);
      if (effect.type === 'sound' && effect.name === 'hit') playRetroHitSound();
    });
  }

  function renderBattleStatusCard(side, view) {
    const isEnemy = side === 'enemy';
    const nameNode = document.getElementById(isEnemy ? 'battle-enemy-name' : 'battle-ally-name');
    const levelNode = document.getElementById(isEnemy ? 'battle-enemy-level' : 'battle-ally-level');
    const hpNode = document.getElementById(isEnemy ? 'battle-enemy-hp' : 'battle-ally-hp');
    const ballsNode = document.getElementById(isEnemy ? 'battle-enemy-balls' : 'battle-ally-balls');
    const typeNode = document.getElementById(isEnemy ? 'battle-enemy-types' : 'battle-ally-types');
    const barId = isEnemy ? 'battle-enemy-bar' : 'battle-ally-bar';
    if (nameNode) nameNode.innerHTML = `${escapeHtml(view.name)}${view.status ? `<span class="battle-status-dot" style="background:${view.status.color};">${escapeHtml(view.status.label)}</span>` : ''}`;
    if (levelNode) levelNode.textContent = `Lv.${view.level}`;
    if (hpNode) hpNode.textContent = `${view.currentHp} / ${view.maxHp}`;
    if (ballsNode) ballsNode.textContent = renderBallCount(isEnemy ? POKEBATTLE.battleEngine.getSnapshot().opponentTeam : POKEBATTLE.battleEngine.getSnapshot().playerTeam);
    if (typeNode) typeNode.innerHTML = (view.types || []).map((type) => renderTypeBadge(type, true)).join('');
    setHpBar(barId, view.currentHp, view.maxHp);
  }

  function renderBattleActions(snap) {

    if (snap.forceSwitch || snap.menu === 'switch') {
      const options = snap.currentBench.length
        ? snap.currentBench.map((entry) => `
            <button type="button" class="action-button" data-battle-switch="${entry.index}">
              <span class="action-title">${escapeHtml(entry.pokemon.name)}</span>
              <span class="action-sub">HP ${entry.pokemon.currentHp}/${entry.pokemon.maxHp} · ${(entry.pokemon.types || []).join(' / ')}</span>
            </button>`).join('')
        : `<button type="button" class="action-button" disabled><span class="action-title">교체 불가</span><span class="action-sub">남은 포켓몬이 없습니다.</span></button>`;
      return options + (!snap.forceSwitch ? `<button type="button" class="action-button" data-battle-root="1"><span class="action-title">뒤로</span><span class="action-sub">기본 메뉴로 돌아갑니다.</span></button>` : '');
    }

    if (snap.menu === 'moves') {
      const infoToggle = `<button type="button" class="battle-mini-toggle" data-battle-toggle-info="1">${snap.showMoveInfo ? '설명닫기' : '설명보기'}</button>`;
      const moveButtons = snap.currentActor.moves.map((move, index) => {
        const koreanDescription = getKoreanOnlyDescription(move.description || '');
        const matchup = getMoveMatchupLabel(move, snap.turnSide === 'ally' ? snap.enemy : snap.ally);
        return `
        <button type="button" class="action-button battle-move-button" data-battle-move="${index}" ${move.currentPP <= 0 ? 'disabled' : ''}>
          <span class="action-title">${escapeHtml(move.nameKo)}</span>
          <div class="battle-move-meta">${renderBattleTypePill(move.type)}${renderMoveCategoryPill(move.category)}<span class="battle-category-pill battle-pp-pill">PP ${move.currentPP}/${move.maxPP}</span></div>
          <span class="action-sub">${move.power == null ? '변화기' : `위력 ${move.power}`} · ${move.accuracy == null ? '명중 -' : `명중 ${move.accuracy}`}</span>
          ${snap.showMoveInfo ? `<div class="battle-move-description">${escapeHtml(koreanDescription || '설명이 없습니다.')}<span class="battle-matchup">${escapeHtml(matchup)}</span></div>` : ''}
        </button>`;
      }).join('');
      return infoToggle + moveButtons + `<button type="button" class="action-button" data-battle-root="1"><span class="action-title">뒤로</span><span class="action-sub">기본 메뉴로 돌아갑니다.</span></button>`;
    }

    if (snap.menu === 'bag') {
      const items = POKEBATTLE.core.getConsumables(snap.currentActorId || snap.playerId).filter((item) => item.amount > 0);
      const cards = items.length ? items.map((item) => `
        <button type="button" class="action-button battle-move-button" data-battle-item="${escapeHtml(item.id)}">
          <span class="action-title">${escapeHtml(item.nameKo)} × ${item.amount}</span>
          <span class="action-sub">${escapeHtml(item.description)}</span>
        </button>
      `).join('') : `<button type="button" class="action-button" disabled><span class="action-title">아이템 없음</span><span class="action-sub">사용 가능한 소비 아이템이 없습니다.</span></button>`;
      return cards + `<button type="button" class="action-button" data-battle-root="1"><span class="action-title">뒤로</span><span class="action-sub">기본 메뉴로 돌아갑니다.</span></button>`;
    }

    if (snap.menu === 'bag-move-target') {
      return snap.currentActor.moves.map((move, index) => `
        <button type="button" class="action-button" data-battle-item-move="${index}">
          <span class="action-title">${escapeHtml(move.nameKo)}</span>
          <span class="action-sub">PP ${move.currentPP}/${move.maxPP} 회복</span>
        </button>
      `).join('') + `<button type="button" class="action-button" data-battle-bag="1"><span class="action-title">뒤로</span><span class="action-sub">가방으로 돌아갑니다.</span></button>`;
    }

    if (snap.menu === 'bag-pokemon-target') {
      const team = (snap.turnSide === 'enemy' ? snap.opponentTeam : snap.playerTeam) || [];
      return team.map((pokemon, index) => `
        <button type="button" class="action-button" data-battle-item-pokemon="${index}">
          <span class="action-title">${escapeHtml(pokemon.currentName || pokemon.name || pokemon.base?.nameKo || '포켓몬')}</span>
          <span class="action-sub">HP ${pokemon.currentHp}/${pokemon.maxHp}${pokemon.currentHp <= 0 ? ' · 기절' : ''}</span>
        </button>
      `).join('') + `<button type="button" class="action-button" data-battle-bag="1"><span class="action-title">뒤로</span><span class="action-sub">가방으로 돌아갑니다.</span></button>`;
    }

    return `
      <button type="button" class="action-button" data-battle-action="fight"><span class="action-title">싸운다</span><span class="action-sub">기술 3개를 선택합니다.</span></button>
      <button type="button" class="action-button" data-battle-action="bag"><span class="action-title">가방</span><span class="action-sub">소비 아이템을 사용합니다.</span></button>
      <button type="button" class="action-button" data-battle-action="pokemon"><span class="action-title">포켓몬</span><span class="action-sub">다른 포켓몬으로 교체합니다.</span></button>
      <button type="button" class="action-button" data-battle-action="info"><span class="action-title">타입 상성표</span><span class="action-sub">공격과 방어 타입 상성을 확인합니다.</span></button>
      ${snap.mode === 'quick' ? `<button type="button" class="action-button" data-battle-action="run"><span class="action-title">도망친다</span><span class="action-sub">테스트 배틀만 즉시 종료합니다.</span></button>` : ''}
    `;
  }

  function bindBattleActions() {

    const root = document.getElementById('battle-action-grid');
    if (!root) return;
    root.querySelectorAll('[data-battle-action]').forEach((button) => button.addEventListener('click', () => POKEBATTLE.battleEngine.handleRootAction(button.dataset.battleAction)));
    root.querySelectorAll('[data-battle-move]').forEach((button) => button.addEventListener('click', () => POKEBATTLE.battleEngine.handleMove(Number(button.dataset.battleMove))));
    root.querySelectorAll('[data-battle-switch]').forEach((button) => button.addEventListener('click', () => POKEBATTLE.battleEngine.handleSwitch(Number(button.dataset.battleSwitch))));
    root.querySelectorAll('[data-battle-item]').forEach((button) => button.addEventListener('click', () => POKEBATTLE.battleEngine.handleBagSelect(button.dataset.battleItem)));
    root.querySelectorAll('[data-battle-item-move]').forEach((button) => button.addEventListener('click', () => POKEBATTLE.battleEngine.handleBagMoveTarget(Number(button.dataset.battleItemMove))));
    root.querySelectorAll('[data-battle-item-pokemon]').forEach((button) => button.addEventListener('click', () => POKEBATTLE.battleEngine.handleBagPokemonTarget(Number(button.dataset.battleItemPokemon))));
    root.querySelectorAll('[data-battle-root]').forEach((button) => button.addEventListener('click', () => POKEBATTLE.battleEngine.setMenu('root')));
    root.querySelectorAll('[data-battle-bag]').forEach((button) => button.addEventListener('click', () => POKEBATTLE.battleEngine.setMenu('bag')));
    root.querySelectorAll('[data-battle-toggle-info]').forEach((button) => button.addEventListener('click', () => POKEBATTLE.battleEngine.toggleMoveInfo()));
    const floatingType = document.getElementById('battle-type-chart-btn');
    if (floatingType && !floatingType.dataset.boundTypeChart) {
      floatingType.dataset.boundTypeChart = '1';
      floatingType.addEventListener('click', () => openTypeChartModal());
    }
    const battleStatsBtn = document.getElementById('battle-stats-btn');
    if (battleStatsBtn && !battleStatsBtn.dataset.boundBattleStats) {
      battleStatsBtn.dataset.boundBattleStats = '1';
      battleStatsBtn.addEventListener('click', () => openBattleStatsModal());
    }
  }


  function openFriendlyShopModal() {
    uiState.activeModal = 'shop';
    const root = modalRoot();
    if (!root) return;
    const core = POKEBATTLE.core;
    const player = core.getActivePlayer();
    let catalog = core.getFriendlyShopInventory ? core.getFriendlyShopInventory(core.state.activePlayerId) : core.getShopCatalog();
    if ((!catalog || !catalog.length) && core.refreshFriendlyShopInventory) catalog = core.refreshFriendlyShopInventory(core.state.activePlayerId);
    const holdables = catalog.filter((item) => item.category === '지닌물건');
    const consumables = catalog.filter((item) => item.category !== '지닌물건');
    const renderCard = (item) => `
      <button type="button" class="placeholder-card item-pick shop-item-card" data-shop-buy="${escapeHtml(item.id)}">
        <div class="item-title-row"><h3>${escapeHtml(item.nameKo)}</h3><span class="mini-badge shop-price">$${item.price}</span></div>
        <p class="shop-item-meta">${escapeHtml(item.category)}</p>
        <p>${escapeHtml(item.battleEffect || item.description || '')}</p>
      </button>`;
    const goods = `
      <div class="placeholder-card shop-section-card"><h3>지닌물건</h3><div class="placeholder-stack">${holdables.map(renderCard).join('') || '<p>현재 진열된 지닌물건이 없습니다.</p>'}</div></div>
      <div class="placeholder-card shop-section-card"><h3>소비 아이템</h3><div class="placeholder-stack">${consumables.map(renderCard).join('') || '<p>현재 진열된 소비 아이템이 없습니다.</p>'}</div></div>`;
    root.innerHTML = `
      <div class="overlay" data-close-modal="1">
        <div class="modal large-modal shop-modal" role="dialog" aria-modal="true" aria-labelledby="shop-title" style="background-image:url('shop.png');background-size:cover;background-position:center; color:#111;">
          <div class="modal-header" style="color:#111;"><div class="modal-title-wrap"><h2 id="shop-title" style="color:#111;">프렌들리숍</h2><p style="color:#111;">보유 재화: <span class="money-text">$${player.money || 0}</span></p></div><button type="button" class="ghost-btn" data-close-modal="1">닫기</button></div>
          <div class="modal-body"><div class="placeholder-card shop-tip-card"><h3 style="color:#111;">게임 팁</h3><p style="color:#111;">프렌들리숍에는 지닌물건 3개와 소비 아이템 4개만 랜덤 진열됩니다. 초반 재화로는 지닌물건 1개와 소비 아이템 1개 정도를 사도록 가격을 맞췄습니다.</p></div><div class="placeholder-stack">${goods}</div></div>
        </div>
      </div>`;
    bindModalClose();
    root.querySelectorAll('[data-shop-buy]').forEach((button) => button.addEventListener('click', () => {
      const result = core.buyShopItem(core.state.activePlayerId, button.dataset.shopBuy);
      if (!result.ok) { showToast(result.message); return; }
      playEffectSound('buying_sound.mp3');
      showToast(`${result.item.nameKo}를 구매했습니다.`);
      openFriendlyShopModal();
      renderAll();
    }));
  }

  function openBattleStatsModal() {
    uiState.activeModal = 'battle-stats';
    const root = modalRoot();
    if (!root) return;
    const sheet = POKEBATTLE.battleEngine?.getBattleStatSheet?.();
    const statRows = [
      { key: 'attack', label: '공격' },
      { key: 'defense', label: '방어' },
      { key: 'spAttack', label: '특공' },
      { key: 'spDefense', label: '특방' },
      { key: 'speed', label: '스피드' }
    ];

    const renderStage = (stage) => {
      const num = Number(stage || 0);
      if (!num) return '±0';
      return num > 0 ? `+${num}` : `${num}`;
    };

    const renderCard = (title, payload) => {
      if (!payload) return `<div class="placeholder-card"><h3>${escapeHtml(title)}</h3><p>현재 배틀에 출전한 포켓몬이 없습니다.</p></div>`;
      const status = payload.status ? `<span class="battle-status-dot" style="background:${payload.status.color};">${escapeHtml(payload.status.label)}</span>` : '';
      const rows = statRows.map((entry) => `
        <div class="battle-stat-sheet-row">
          <span class="battle-stat-sheet-label">${entry.label}</span>
          <span class="battle-stat-sheet-values">
            <span>현재 <strong>${payload.currentStats[entry.key]}</strong></span>
            <span>실능력치 ${payload.actualStats[entry.key]}</span>
            <span>랭크 ${renderStage(payload.stages[entry.key])}</span>
          </span>
        </div>
      `).join('');
      return `
        <div class="placeholder-card battle-stat-sheet-card">
          <div class="item-title-row"><h3>${escapeHtml(title)} · ${escapeHtml(payload.name)} ${status}</h3><span class="mini-badge">Lv.${payload.level}</span></div>
          <p>종족치 기준: 공 ${payload.baseStats.attack} / 방 ${payload.baseStats.defense} / 특공 ${payload.baseStats.spAttack} / 특방 ${payload.baseStats.spDefense} / 스피드 ${payload.baseStats.speed}</p>
          ${Array.isArray(payload.heldItems) && payload.heldItems.length ? `<p style="color:#ffd47a;">지닌물건 효과: ${payload.heldItems.map((item) => escapeHtml(item.battleEffect || item.description || item.nameKo)).join(' / ')}</p>` : ''}
          <div class="battle-stat-sheet-grid">${rows}</div>
        </div>
      `;
    };

    root.innerHTML = `
      <div class="overlay" data-close-modal="1">
        <div class="modal large-modal" role="dialog" aria-modal="true" aria-labelledby="battle-stats-title">
          <div class="modal-header">
            <div class="modal-title-wrap">
              <h2 id="battle-stats-title">스탯 확인</h2>
              <p>현재값은 랭크 변화와 상태이상까지 반영된 전투 중 수치입니다.</p>
            </div>
            <button type="button" class="ghost-btn" data-close-modal="1">닫기</button>
          </div>
          <div class="modal-body">
            <div class="placeholder-stack">
              ${renderCard('내 포켓몬', sheet?.ally)}
              ${renderCard('상대 포켓몬', sheet?.enemy)}
            </div>
          </div>
        </div>
      </div>
    `;

    root.querySelectorAll('[data-close-modal]').forEach((button) => button.addEventListener('click', closeModal));
    const overlay = root.querySelector('.overlay');
    if (overlay) overlay.addEventListener('click', (event) => { if (event.target === overlay) closeModal(); });
  }

  function openWelcomeModal() {
    uiState.activeModal = 'welcome';
    const root = modalRoot();
    if (!root) return;
    root.innerHTML = `
      <div class="overlay" id="welcome-overlay">
        <div class="modal welcome-card" role="dialog" aria-modal="true" aria-labelledby="welcome-title">
          <div class="modal-header">
            <div class="modal-title-wrap">
              <h2 id="welcome-title">환영합니다!</h2>
              <p>게임을 시작할 준비가 끝났습니다.</p>
            </div>
          </div>
          <div class="modal-body">
            던전을 탐험하고 스쿼드를 관리해서 포켓몬 리그 챔피언이 되세요.
            <div class="welcome-dismiss">화면 아무 곳이나 터치하면 닫힙니다.</div>
          </div>
        </div>
      </div>
    `;
    const overlay = document.getElementById('welcome-overlay');
    if (overlay) overlay.addEventListener('click', closeModal, { once: true });
  }


  function openAbilityModal(runtimePokemon) {
    uiState.activeModal = 'ability';
    const root = modalRoot();
    if (!root || !runtimePokemon) return;
    const activeAbility = runtimePokemon.ability || runtimePokemon.visibleAbility || runtimePokemon.base?.ability || '없음';
    const hiddenAbility = runtimePokemon.hiddenAbility || runtimePokemon.base?.hiddenAbility || null;
    const abilityDesc = runtimePokemon.base?.abilityDescription || runtimePokemon.base?.abilityText || POKEBATTLE.core?.getAbilityDescription?.(activeAbility) || '현재 포켓몬에게 적용되는 특성의 배틀 효과를 확인할 수 있습니다.';
    const hiddenDesc = hiddenAbility ? (runtimePokemon.base?.hiddenAbilityDescription || runtimePokemon.base?.hiddenAbilityText || POKEBATTLE.core?.getAbilityDescription?.(hiddenAbility) || '숨겨진 특성의 배틀 효과를 확인할 수 있습니다.') : '';
    root.innerHTML = `
      <div class="overlay">
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="ability-title">
          <div class="modal-header">
            <div class="modal-title-wrap">
              <h2 id="ability-title">${escapeHtml(runtimePokemon.currentName)} · 특성 정보</h2>
              <p>현재 적용 특성과 숨겨진 특성 정보를 확인할 수 있습니다.</p>
            </div>
            <button type="button" class="close-btn" id="close-modal-btn">✕</button>
          </div>
          <div class="modal-body">
            <div class="placeholder-stack">
              <div class="placeholder-card">
                <div class="item-title-row"><h3>${escapeHtml(activeAbility)}</h3><span class="mini-badge">현재 적용</span></div>
                <p>${escapeHtml(abilityDesc)}</p>
              </div>
              ${hiddenAbility ? `<div class="placeholder-card"><div class="item-title-row"><h3>${escapeHtml(hiddenAbility)}</h3><span class="mini-badge">숨겨진 특성</span></div><p>${escapeHtml(hiddenDesc)}</p></div>` : ''}
            </div>
          </div>
        </div>
      </div>
    `;
    const close = document.getElementById('close-modal-btn');
    if (close) close.addEventListener('click', closeModal);
    const overlay = root.querySelector('.overlay');
    if (overlay) overlay.addEventListener('click', (event) => { if (event.target === overlay) closeModal(); });
  }

  function openMovesModal(runtimePokemon) {
    uiState.activeModal = 'moves';
    const root = modalRoot();
    const moves = Array.isArray(runtimePokemon.base.moves) ? runtimePokemon.base.moves : [];
    root.innerHTML = `
      <div class="overlay">
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="moves-title">
          <div class="modal-header">
            <div class="modal-title-wrap">
              <h2 id="moves-title">${escapeHtml(runtimePokemon.currentName)} · 기술 정보</h2>
              <p>대표 기술 3개와 세부 설명을 확인할 수 있습니다.</p>
            </div>
            <button type="button" class="close-btn" id="close-modal-btn">✕</button>
          </div>
          <div class="modal-body">
            <div class="placeholder-stack">
              ${moves.slice(0, 3).map((move) => `
                <div class="placeholder-card">
                  <div class="item-title-row"><h3>${escapeHtml(move.nameKo)} <span class="accent-note">(${escapeHtml(move.nameEn || '')})</span></h3>${renderTypeBadge(move.type, true)}</div>
                  <div class="move-meta-inline">
                    <span style="color:#ff9c43;font-weight:800;"><strong>위력</strong> ${move.power == null ? '-' : move.power}</span>
                    <span><strong>명중률</strong> ${move.accuracy == null ? '-' : `${move.accuracy}`}</span>
                    <span><strong>분류</strong> ${escapeHtml(move.category)}</span>
                  </div>
                  <p>${escapeHtml(move.description || '')}</p>
                  ${move.logicExplanation ? `<p class="section-caption">${escapeHtml(move.logicExplanation)}</p>` : ''}
                </div>`).join('')}
            </div>
          </div>
        </div>
      </div>
    `;
    bindModalClose();
  }

  function openSettingsModal() {
    uiState.activeModal = 'settings';
    renderSettingsModal();
  }

  function renderSettingsModal() {
    const core = POKEBATTLE.core;
    const root = modalRoot();
    if (!root || uiState.activeModal !== 'settings') return;
    root.innerHTML = `
      <div class="overlay">
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="settings-title">
          <div class="modal-header">
            <div class="modal-title-wrap"><h2 id="settings-title">설정</h2><p>효과음, 배경음악 음량, 애니메이션 속도를 조정합니다.</p></div>
            <button type="button" class="close-btn" id="close-modal-btn">✕</button>
          </div>
          <div class="modal-body">
            <div class="settings-grid">
              <section class="settings-section">
                <h3>효과음</h3>
                <div class="settings-row">
                  <button type="button" class="settings-choice ${core.state.settings.sfx ? 'active' : ''}" data-setting-key="sfx" data-setting-value="on">ON</button>
                  <button type="button" class="settings-choice ${!core.state.settings.sfx ? 'active' : ''}" data-setting-key="sfx" data-setting-value="off">OFF</button>
                </div>
              </section>
              <section class="settings-section">
                <h3>배경음악 음량</h3>
                <div class="settings-row">
                  <button type="button" class="settings-choice ${Number(core.state.settings.bgmVolume || 0) === 0 ? 'active' : ''}" data-setting-key="bgmVolume" data-setting-value="0">음소거</button>
                  <button type="button" class="settings-choice ${Math.abs(Number(core.state.settings.bgmVolume || 0) - 0.3) < 0.001 ? 'active' : ''}" data-setting-key="bgmVolume" data-setting-value="0.3">30%</button>
                  <button type="button" class="settings-choice ${Math.abs(Number(core.state.settings.bgmVolume || 0) - 0.6) < 0.001 ? 'active' : ''}" data-setting-key="bgmVolume" data-setting-value="0.6">60%</button>
                  <button type="button" class="settings-choice ${Math.abs(Number(core.state.settings.bgmVolume || 0) - 1) < 0.001 ? 'active' : ''}" data-setting-key="bgmVolume" data-setting-value="1">100%</button>
                </div>
              </section>
              <section class="settings-section">
                <h3>애니메이션 속도</h3>
                <div class="settings-row">
                  <button type="button" class="settings-choice ${core.state.settings.animationSpeed === '상' ? 'active' : ''}" data-setting-key="animationSpeed" data-setting-value="상">상</button>
                  <button type="button" class="settings-choice ${core.state.settings.animationSpeed === '하' ? 'active' : ''}" data-setting-key="animationSpeed" data-setting-value="하">하</button>
                </div>
              </section>
            </div>
          </div>
        </div>
      </div>
    `;
    bindModalClose();
    root.querySelectorAll('[data-setting-key]').forEach((button) => {
      button.addEventListener('click', () => {
        if (button.dataset.settingKey === 'sfx') core.setSetting('sfx', button.dataset.settingValue === 'on');
        if (button.dataset.settingKey === 'bgmVolume') core.setSetting('bgmVolume', Number(button.dataset.settingValue));
        if (button.dataset.settingKey === 'animationSpeed') core.setSetting('animationSpeed', button.dataset.settingValue);
      });
    });
  }

  function openTypeChartModal() {
    uiState.activeModal = 'type-chart';
    const root = modalRoot();
    if (!root) return;
    root.innerHTML = `
      <div class="overlay">
        <div class="modal modal-type-chart-image" role="dialog" aria-modal="true" aria-labelledby="type-chart-title">
          <div class="modal-header">
            <div class="modal-title-wrap"><h2 id="type-chart-title">타입 상성표</h2><p>공격과 방어를 구분해 2배, 1/2배, 0배를 한눈에 볼 수 있게 정리했습니다.</p></div>
            <button type="button" class="close-btn" id="close-modal-btn">✕</button>
          </div>
          <div class="modal-body type-chart-image-body">
            <img class="type-chart-reference-image" alt="포켓몬 타입 상성표" src="${TYPE_CHART_DATA_URI}" />
          </div>
        </div>
      </div>
    `;
    bindModalClose();
  }


  function openChatModal() {
    uiState.activeModal = 'chat';
    const root = modalRoot();
    if (!root) return;
    const messages = (uiState.chatMessages || []).map((message) => `
      <div class="placeholder-card" style="padding:10px 12px;background:rgba(255,255,255,0.92);">
        <div style="font-size:12px;font-weight:800;color:#6f89a8;">${escapeHtml(message.author)}</div>
        <div style="margin-top:4px;white-space:pre-wrap;word-break:break-word;color:#111;">${escapeHtml(message.text)}</div>
      </div>
    `).join('') || '<div class="empty-state">아직 채팅이 없습니다.</div>';
    root.innerHTML = `
      <div class="overlay" id="chat-overlay">
        <div class="modal" id="chat-modal-panel" role="dialog" aria-modal="true" aria-labelledby="chat-title">
          <div class="modal-header">
            <div class="modal-title-wrap"><h2 id="chat-title">채팅</h2><p>간단한 메모나 대화를 남길 수 있습니다.</p></div>
            <button type="button" class="ghost-btn" data-close-modal="1">닫기</button>
          </div>
          <div class="modal-body">
            <div class="placeholder-stack" style="max-height:280px;overflow:auto;">${messages}</div>
            <div style="height:12px"></div>
            <textarea id="chat-input" rows="4" placeholder="채팅을 입력하세요." style="width:100%;resize:none;border-radius:16px;border:1px solid rgba(126,207,255,0.18);background:rgba(8,12,18,0.82);color:#f8fbff;padding:12px 14px;box-sizing:border-box;"></textarea>
            <div style="height:12px"></div>
            <div style="display:flex;justify-content:flex-end;gap:8px;">
              <button type="button" class="ghost-btn" data-close-modal="1">닫기</button>
              <button type="button" class="chip-btn" id="send-chat-btn">전송</button>
            </div>
          </div>
        </div>
      </div>`;
    root.querySelectorAll('[data-close-modal]').forEach((button) => button.addEventListener('click', closeModal));
    const overlay = document.getElementById('chat-overlay');
    const panel = document.getElementById('chat-modal-panel');
    if (overlay) overlay.addEventListener('click', (event) => { if (event.target === overlay) closeModal(); });
    if (panel) panel.addEventListener('click', (event) => event.stopPropagation());
    const input = document.getElementById('chat-input');
    const send = document.getElementById('send-chat-btn');
    const submit = () => {
      const text = String(input?.value || '').trim();
      if (!text) return;
      const activePlayer = POKEBATTLE.core?.getActivePlayer?.();
      uiState.chatMessages.push({ author: activePlayer?.name || '플레이어', text });
      openChatModal();
    };
    if (send) send.addEventListener('click', submit);
    if (input) input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        submit();
      }
    });
  }

  function openBattleEndModal(title, body, onClose) {
    uiState.activeModal = 'battle-end';
    uiState.afterBattleModalClose = onClose || null;
    const root = modalRoot();
    root.innerHTML = `
      <div class="overlay">
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="battle-end-title">
          <div class="modal-header">
            <div class="modal-title-wrap"><h2 id="battle-end-title">${escapeHtml(title)}</h2><p>배틀 결과</p></div>
          </div>
          <div class="modal-body">
            <p>${escapeHtml(body)}</p>
            <div style="margin-top:16px;display:flex;justify-content:flex-end;"><button type="button" class="chip-btn" id="battle-end-confirm">확인</button></div>
          </div>
        </div>
      </div>
    `;
    const button = document.getElementById('battle-end-confirm');
    if (button) {
      button.addEventListener('click', () => {
        const cb = uiState.afterBattleModalClose;
        closeModal();
        if (typeof cb === 'function') cb();
      });
    }
  }

  function bindModalClose() {
    const root = modalRoot();
    const overlay = root?.querySelector('.overlay');
    root?.querySelectorAll('[data-close-modal], #close-modal-btn').forEach((button) => {
      button.addEventListener('click', closeModal);
    });
    if (overlay) {
      overlay.addEventListener('click', (event) => {
        if (event.target === overlay) closeModal();
      });
    }
  }

  function closeModal() {
    uiState.activeModal = null;
    uiState.afterBattleModalClose = null;
    const root = modalRoot();
    if (root) root.innerHTML = '';
  }

  function formatTypeEntries(entries) {
    if (!entries || !entries.length) return `<div><span class="multiplier one">1배</span> · 특수 상성 없음</div>`;
    return entries.map((entry) => {
      const cls = entry.multiplier === 2 ? 'two' : entry.multiplier === 1.5 ? 'stab' : entry.multiplier === 0.5 ? 'half' : entry.multiplier === 0 ? 'zero' : 'one';
      return `<div><span class="multiplier ${cls}">${entry.multiplier}배</span> · ${escapeHtml(entry.type)}</div>`;
    }).join('');
  }


  function renderBattleTypePill(type) {
    const color = POKEBATTLE.core?.state?.typeColors?.[type] || '#7b8aa0';
    return `<span class="battle-type-pill" style="background:${color};color:${getContrastColor(color)};border:1px solid rgba(255,255,255,0.12);">${escapeHtml(type || '-')}</span>`;
  }

  function renderMoveCategoryPill(category) {
    const normalized = category === '물리' ? 'physical' : category === '특수' ? 'special' : 'status';
    return `<span class="battle-category-pill ${normalized}">${escapeHtml(category || '-')}</span>`;
  }

  function renderTypeBadge(type, compact) {
    const color = POKEBATTLE.core?.state?.typeColors?.[type] || '#7b8aa0';
    return `<span class="type-badge" style="background:${color};color:${getContrastColor(color)};${compact ? 'padding:4px 9px;' : ''}">${escapeHtml(type)}</span>`;
  }

  function renderAvatar(base, size) {
    const media = getPokemonMedia(base);
    const dimension = size ? `${size}px` : '62px';
    if (media) {
      if (media.type === 'video') {
        return `<span class="pokemon-avatar sprite-avatar" style="width:${dimension};height:${dimension};"><video class="pokemon-sprite-video" src="${media.src}" ${media.poster ? `poster="${media.poster}"` : ''} autoplay muted loop playsinline webkit-playsinline preload="auto"></video></span>`;
      }
      return `<span class="pokemon-avatar sprite-avatar" style="width:${dimension};height:${dimension};"><img class="pokemon-sprite" src="${media.src}" alt="${escapeHtml(base?.nameKo || '포켓몬')}"></span>`;
    }
    return `<span class="pokemon-avatar" style="${avatarStyle(base, size)}"></span>`;
  }


  function renderBattleMonMarkup(id, className, base, size) {
    const media = getPokemonMedia(base);
    if (media) {
      if (media.type === 'video') {
        return `<div id="${id}" class="${className} sprite-battle-mon"><video class="battle-mon-video" src="${media.src}" ${media.poster ? `poster=\"${media.poster}\"` : ''} autoplay muted loop playsinline webkit-playsinline preload="auto" style="max-width:${size}px;max-height:${size}px;"></video></div>`;
      }
      return `<div id="${id}" class="${className} sprite-battle-mon"><img class="battle-mon-sprite" src="${media.src}" alt="${escapeHtml(base?.nameKo || '포켓몬')}" style="max-width:${size}px;max-height:${size}px;"></div>`;
    }
    return `<div id="${id}" class="${className}" style="${avatarStyle(base)}background-blend-mode:normal;opacity:1;z-index:6;mix-blend-mode:normal;"></div>`;
  }

  function avatarStyle(base, size) {
    const appearance = base?.appearance || {};
    const bars = Array.isArray(appearance.bars) ? appearance.bars : ['#ffffff', '#a5ccef'];
    const coreColor = appearance.core || '#7ecfff';
    const outerColor = appearance.outer && appearance.outer !== 'transparent' ? appearance.outer : shadeColor(coreColor, -18);
    const dimension = size ? `width:${size}px;height:${size}px;` : '';
    return `background-color:${coreColor};background-image:radial-gradient(circle at 32% 28%, ${lightenColor(coreColor, 24)} 0%, ${coreColor} 46%, ${outerColor} 100%);color:${bars[0] || '#fff'};${dimension}--bar-right:${bars[1] || bars[0] || '#fff'};opacity:1;filter:none;`;
  }

  function renderBallCount(team) {
    return team.map((pokemon) => pokemon.currentHp > 0 ? '●' : '○').join(' ');
  }

  function setText(id, value) {
    const node = document.getElementById(id);
    if (node) node.textContent = value;
  }

  function setHpBar(id, current, max) {
    const node = document.getElementById(id);
    if (!node) return;
    const percent = Math.max(0, Math.min(100, (current / Math.max(1, max)) * 100));
    const speed = POKEBATTLE.core?.state?.settings?.animationSpeed === '하' ? '980ms' : '760ms';
    node.style.transitionDuration = speed;
    node.style.width = `${percent}%`;
    if (percent <= 25) node.style.background = 'linear-gradient(90deg,#f26d6d,#ff9f7a)';
    else if (percent <= 50) node.style.background = 'linear-gradient(90deg,#ffb347,#ffd166)';
    else node.style.background = 'linear-gradient(90deg,#56ca7b,#88e9a5)';
  }

  function flashBattleMon(target) {
    const node = document.getElementById(target === 'ally' ? 'battle-ally-mon' : 'battle-enemy-mon');
    if (!node) return;
    node.classList.remove('hit');
    void node.offsetWidth;
    node.classList.add('hit');
  }

  function faintBattleMon(target) {
    const node = document.getElementById(target === 'ally' ? 'battle-ally-mon' : 'battle-enemy-mon');
    if (!node) return;
    node.classList.remove('fainting');
    void node.offsetWidth;
    node.classList.add('fainting');
  }

  function playRetroHitSound() {
    if (!POKEBATTLE.core?.state?.settings?.sfx) return;
    const AudioCtx = window.AudioContext || window.webkitAudioContext;
    if (!AudioCtx) return;
    if (!uiState.audioContext) uiState.audioContext = new AudioCtx();
    const ctx = uiState.audioContext;
    const now = ctx.currentTime;

    const makePulse = (time, freqA, freqB, gainPeak) => {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = 'square';
      osc.frequency.setValueAtTime(freqA, time);
      osc.frequency.exponentialRampToValueAtTime(freqB, time + 0.028);
      gain.gain.setValueAtTime(0.0001, time);
      gain.gain.exponentialRampToValueAtTime(gainPeak, time + 0.004);
      gain.gain.exponentialRampToValueAtTime(0.0001, time + 0.038);
      osc.connect(gain).connect(ctx.destination);
      osc.start(time);
      osc.stop(time + 0.04);
    };

    makePulse(now, 620, 240, 0.05);
    makePulse(now + 0.03, 480, 180, 0.04);
  }


  function getKoreanOnlyDescription(text) {
    return String(text || '')
      .replace(/\([^)]*[A-Za-z][^)]*\)/g, '')
      .replace(/[A-Za-z][A-Za-z0-9 .,!'’:-]*/g, '')
      .replace(/\s+/g, ' ')
      .trim();
  }

  function getMoveMatchupLabel(move, enemy) {
    if (!move || move.category === '변화' || !enemy) return `${enemy?.name || '상대'}에게 보통`;
    const effectiveness = typeof POKEBATTLE.battleEngine?.getTypeEffectivenessValue === 'function'
      ? POKEBATTLE.battleEngine.getTypeEffectivenessValue(move.type, enemy)
      : 1;
    const label = effectiveness > 1 ? '강함' : effectiveness < 1 ? '약함' : '보통';
    return `${enemy.name}에게 ${label}`;
  }


  function injectRuntimeStyles() {
    if (document.getElementById('pokebattle-runtime-style')) return;
    const style = document.createElement('style');
    style.id = 'pokebattle-runtime-style';
    style.textContent = `
      .battle-status-dot{display:inline-flex;align-items:center;justify-content:center;margin-left:8px;padding:2px 8px;border-radius:999px;font-size:.66rem;font-weight:800;color:#101722;vertical-align:middle;}
      .league-done{opacity:.78;border-color:rgba(104,211,145,.3)!important;}
    `;
    document.head.appendChild(style);
  }

  function parseHexColor(hex) {
    const normalized = String(hex || '').replace('#', '');
    if (!/^[0-9a-fA-F]{6}$/.test(normalized)) return [126, 207, 255];
    return [
      parseInt(normalized.slice(0, 2), 16),
      parseInt(normalized.slice(2, 4), 16),
      parseInt(normalized.slice(4, 6), 16)
    ];
  }

  function rgbToHex(r, g, b) {
    return `#${[r, g, b].map((value) => Math.max(0, Math.min(255, value)).toString(16).padStart(2, '0')).join('')}`;
  }

  function lightenColor(hex, amount) {
    const [r, g, b] = parseHexColor(hex);
    return rgbToHex(r + amount, g + amount, b + amount);
  }

  function shadeColor(hex, amount) {
    const [r, g, b] = parseHexColor(hex);
    return rgbToHex(r + amount, g + amount, b + amount);
  }

  function getContrastColor(hex) {
    const normalized = String(hex || '').replace('#', '');
    if (!/^[0-9a-fA-F]{6}$/.test(normalized)) return '#fff';
    const r = parseInt(normalized.slice(0, 2), 16);
    const g = parseInt(normalized.slice(2, 4), 16);
    const b = parseInt(normalized.slice(4, 6), 16);
    const yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;
    return yiq >= 160 ? '#122030' : '#ffffff';
  }

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function escapeRegExp(value) {
    return String(value || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function highlightPokemonNameText(text, pokemonName) {
    const safeText = escapeHtml(text || '');
    const name = String(pokemonName || '').trim();
    if (!name) return safeText;
    const pattern = new RegExp(escapeRegExp(name), 'g');
    return safeText.replace(pattern, `<span style="color:#ff9c43;font-weight:800;">${escapeHtml(name)}</span>`);
  }

  function openRewardModal(payload) {
    uiState.activeModal = 'reward';
    const root = modalRoot();
    if (!root) return;
    const lines = Array.isArray(payload?.lines) ? payload.lines : [];
    const cards = lines.map((line) => {
      if (line && typeof line === 'object' && line.html) return `<div class="placeholder-card"><p>${line.html}</p></div>`;
      return `<div class="placeholder-card"><p>${escapeHtml(line)}</p></div>`;
    }).join('');
    root.innerHTML = `
      <div class="overlay" id="reward-overlay">
        <div class="modal" role="dialog" aria-modal="true" aria-labelledby="reward-title">
          <div class="modal-header">
            <div class="modal-title-wrap">
              <h2 id="reward-title">${escapeHtml(payload?.title || '보상')}</h2>
              <p>획득한 보상을 확인했습니다.</p>
            </div>
            <button type="button" class="close-btn" data-close-reward>✕</button>
          </div>
          <div class="modal-body">
            <div class="placeholder-stack">${cards}</div>
            <div style="height:12px"></div>
            <button type="button" class="action-button" data-close-reward><span class="action-title">확인</span><span class="action-sub">로비로 돌아갑니다.</span></button>
          </div>
        </div>
      </div>`;
    root.querySelectorAll('[data-close-reward]').forEach((button) => button.addEventListener('click', closeModal));
  }

  function showToast(message) {
    const root = modalRoot();
    if (!root) return;
    const existing = document.getElementById('inline-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.id = 'inline-toast';
    toast.style.position = 'fixed';
    toast.style.left = '50%';
    toast.style.bottom = 'calc(104px + env(safe-area-inset-bottom, 0px))';
    toast.style.transform = 'translateX(-50%)';
    toast.style.padding = '10px 14px';
    toast.style.borderRadius = '999px';
    toast.style.background = 'rgba(10, 14, 22, 0.88)';
    toast.style.border = '1px solid rgba(126, 207, 255, 0.18)';
    toast.style.color = '#f8fbff';
    toast.style.fontSize = '0.8rem';
    toast.style.fontWeight = '700';
    toast.style.zIndex = '40';
    toast.style.boxShadow = '0 16px 30px rgba(0,0,0,0.28)';
    toast.textContent = message;
    root.appendChild(toast);
    if (uiState.toastTimer) clearTimeout(uiState.toastTimer);
    uiState.toastTimer = window.setTimeout(() => toast.remove(), 1600);
  }

  POKEBATTLE.ui = {
    init,
    renderAll,
    showScreen,
    openWelcomeModal,
    openMovesModal,
    openSettingsModal,
    renderSettingsModal,
    openTypeChartModal,
    openChatModal,
    closeModal,
    openBattleEndModal,
    openRewardModal,
    showToast,
    syncBgmVolume,
    playEffectSound
  };
})();
